---
import { ArrowUp, Flame } from 'lucide-astro';

interface Props {
  eventName: string;
  topHref?: string; // back-to-top target for this page
  showVolunteer?: boolean; // hide on the volunteer page itself (self-link)
}

const { eventName, topHref = '#hero', showVolunteer = true } = Astro.props;
---

<footer class="bg-stone-950 pb-10">
  <span class="footer__rule block w-full h-0.5 gradient-rainbow-rule mb-8"></span>
  <div
    class="footer__inner flex flex-col gap-10 max-w-4xl mx-auto px-8 md:flex-row md:justify-between md:items-end"
  >
    <div class="footer__left flex flex-col gap-2">
      <div class="footer__title font-display text-xl tracking-[0.06em] gradient-rainbow-text">
        {eventName}
      </div>
      <p class="text-stone-400 text-sm">
        Organized by the <a
          href="https://www.evergreenmtb.org/chapters/southwest"
          target="_blank"
          class="underline">Evergreen MTB Alliance Southwest Chapter</a
        >
      </p>
      {
        showVolunteer && (
          <a
            href="/volunteer"
            class="footer__volunteer mt-1 inline-flex w-fit items-center gap-1.5 text-xs font-semibold tracking-widest uppercase text-stone-400 transition-colors duration-200 hover:text-amber-700"
          >
            <Flame size={13} strokeWidth={2.5} /> Volunteer
          </a>
        )
      }
    </div>
    <div class="footer__right flex flex-col gap-3">
      <div
        class="footer__tagline font-display text-2xl tracking-[0.04em] text-stone-100/40 text-left md:text-right"
      >
        See you on the trails.
      </div>
      <a
        href={topHref}
        class="footer__top flex items-center gap-1.5 text-xs font-semibold tracking-widest uppercase text-stone-400 transition-colors duration-200 hover:text-amber-700 text-left md:justify-end md:text-right"
        ><ArrowUp size={13} strokeWidth={2.5} /> Back to top</a
      >
    </div>
  </div>
</footer>
