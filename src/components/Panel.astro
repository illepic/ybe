---
import { Link, Check } from 'lucide-astro';

interface Props {
  id?: string;
  bgImage?: string;
  mobileBgImage?: string;
  scroll?: boolean; // disables parallax fixed attachment (e.g. gallery)
  class?: string;
}

const { id, bgImage, mobileBgImage, scroll = false, class: className = '' } = Astro.props;

const bgStyle = bgImage
  ? [`--bg-desktop: url('${bgImage}')`, mobileBgImage ? `--bg-mobile: url('${mobileBgImage}')` : '']
      .filter(Boolean)
      .join('; ')
  : undefined;
---

<section
  {id}
  class:list={[
    'panel',
    'relative min-h-screen flex items-center justify-center',
    'bg-cover bg-center bg-no-repeat bg-bg',
    scroll ? 'bg-scroll' : 'bg-scroll md:bg-fixed',
    className,
  ]}
  style={bgStyle}
>
  <!-- Dark overlay — replaces ::before pseudo-element -->
  <div class="absolute inset-0 bg-black/80" aria-hidden="true"></div>

  <!-- Content -->
  <div
    class="panel__inner relative z-1 w-full max-w-4xl mx-auto text-center
           pt-22 px-5 pb-14
           md:pt-28 md:px-8 md:pb-20"
  >
    <slot />
  </div>

  <!-- Section link copy button — only rendered when panel has an id -->
  {
    id && (
      <button
        x-data="{ copied: false }"
        x-on:click={`
          navigator.clipboard.writeText(window.location.origin + window.location.pathname + '#${id}');
          copied = true;
          setTimeout(() => copied = false, 1500);
        `}
        aria-label={`Copy link to #${id} section`}
        class="absolute top-4 right-4 z-3
               p-1.5 rounded
               text-stone-400 opacity-20 hover:opacity-100 hover:text-stone-100
               transition-all duration-200
               focus-visible:opacity-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-400"
      >
        <span x-show="!copied" aria-hidden="true">
          <Link size={14} strokeWidth={2} />
        </span>
        <span x-show="copied" x-cloak aria-hidden="true" class="text-amber-500">
          <Check size={14} strokeWidth={2.5} />
        </span>
      </button>
    )
  }

  <!-- Position wrapper owns the absolute placement; PhotoCredit is unaware -->
  <div class="absolute bottom-4 right-4 z-[2]">
    <slot name="credit" />
  </div>
</section>
