---
import { Medal } from 'lucide-astro';
import { cdn } from '../lib/utils/cdn';

export interface Sponsor {
  name: string;
  logo?: string;
  url?: string;
  screen?: boolean; // invert + screen blend (white-bg logos)
  raw?: boolean; // no filter — show as-is (opaque JPGs)
}

interface Props {
  tier: 'gold' | 'silver' | 'bronze';
  sponsors: Sponsor[];
  campaign?: string; // e.g. 'ybe2026' — appended as UTM to outbound links
}

const { tier, sponsors, campaign } = Astro.props;

// Append UTM params so sponsors can see referral traffic from yacoltburn.bike
const withUtm = (url: string, name: string) => {
  if (!campaign) return url;
  try {
    const u = new URL(url);
    u.searchParams.set('utm_source', 'yacoltburn.bike');
    u.searchParams.set('utm_medium', 'sponsor');
    u.searchParams.set('utm_campaign', campaign);
    u.searchParams.set(
      'utm_content',
      name
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/(^-|-$)/g, '')
    );
    return u.toString();
  } catch {
    return url;
  }
};

// SVGs bypass the CDN (don't rasterize a vector logo); everything else goes
// through cdn() at 200×200. cdn() already handles the dev passthrough.
const optimizeLogo = (path: string) =>
  path.endsWith('.svg') ? path : cdn(path, { w: '200', h: '200' });

const CONFIG = {
  gold: {
    label: 'Gold',
    labelColor: 'text-amber-500',
    gridCols: 'grid-cols-1',
    gridMaxW: 'max-w-55 mx-auto',
    logoOpacity: 'opacity-90',
    nameSize: 'text-sm',
    cellBg: 'bg-amber-500/10 border-amber-500/30',
  },
  silver: {
    label: 'Silver',
    labelColor: 'text-stone-300',
    gridCols: 'grid-cols-2 md:grid-cols-4',
    gridMaxW: '',
    logoOpacity: 'opacity-70',
    nameSize: 'text-xs',
    cellBg: 'bg-stone-300/10 border-stone-300/20',
  },
  bronze: {
    label: 'Bronze',
    labelColor: 'text-amber-600',
    gridCols: 'grid-cols-2 md:grid-cols-5',
    gridMaxW: '',
    logoOpacity: 'opacity-60',
    nameSize: 'text-xs',
    cellBg: 'bg-amber-600/10 border-amber-600/20',
  },
};

const c = CONFIG[tier];
---

<div class="sponsor-tier mt-11">
  <div
    class:list={[
      'sponsor-tier__label',
      'flex items-center justify-center gap-1.5 text-xs font-semibold tracking-widest uppercase mb-5',
      c.labelColor,
    ]}
  >
    <Medal size={12} strokeWidth={2.5} />
    {c.label}
  </div>

  <div class:list={['grid gap-3', c.gridCols, c.gridMaxW]}>
    {
      sponsors.map((sponsor) => {
        const inner = sponsor.logo ? (
          <img
            src={optimizeLogo(sponsor.logo)}
            alt={sponsor.name}
            loading="lazy"
            decoding="async"
            class:list={[
              'w-full h-full object-contain transition-opacity duration-200 group-hover:opacity-100',
              c.logoOpacity,
              sponsor.screen ? 'invert mix-blend-screen' : sponsor.raw ? '' : 'brightness-0 invert',
            ]}
          />
        ) : (
          <span
            class:list={[
              'font-semibold tracking-wide uppercase text-center text-stone-400 leading-tight',
              c.nameSize,
            ]}
          >
            {sponsor.name}
          </span>
        );

        const cell = (
          <div
            class:list={[
              'group aspect-square flex items-center justify-center p-4 border rounded',
              c.cellBg,
            ]}
          >
            {inner}
          </div>
        );

        return sponsor.url ? (
          <a href={withUtm(sponsor.url, sponsor.name)} target="_blank" rel="noopener">
            {cell}
          </a>
        ) : (
          cell
        );
      })
    }
  </div>
</div>
