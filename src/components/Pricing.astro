---
interface Props {
  title?: string;
  id?: string;
  class?: string;
}

const { title = 'Pricing', id, class: className = '' } = Astro.props;
---

<div
  id={id}
  class:list={[
    'pricing',
    'max-w-[460px]',
    'mx-auto',
    'bg-black/65',
    'border',
    'border-white/10',
    'rounded',
    'px-5',
    'pt-5',
    'pb-6',
    'md:px-8',
    'md:pt-7',
    'md:pb-8',
    className,
  ]}
>
  <h3
    class="pricing__title font-display font-bold text-[clamp(1.6rem,4vw,2.6rem)] tracking-[0.03em] leading-[0.93] text-stone-100 mb-5 text-left"
  >
    {title}
  </h3>
  <div class="divide-y divide-white/9">
    <slot name="rows" />
  </div>
  <slot name="cta" />
</div>
