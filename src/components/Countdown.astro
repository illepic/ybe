---
interface Props {
  targetDate: string; // ISO 8601, e.g. '2026-06-20T09:00:00-07:00'
}

const { targetDate } = Astro.props;
---

<div
  x-data={`countdown('${targetDate}')`}
  class="flex justify-center gap-6 mt-8 text-xs font-medium tracking-widest uppercase text-stone-400"
>
  <span>
    <b
      class="block font-display text-4xl tracking-[0.04em] leading-none mb-1 text-amber-500"
      x-text="days"></b>
    days
  </span>
  <span>
    <b
      class="block font-display text-4xl tracking-[0.04em] leading-none mb-1 text-cyan-400"
      x-text="hours"></b>
    hrs
  </span>
  <span>
    <b
      class="block font-display text-4xl tracking-[0.04em] leading-none mb-1 text-purple-400"
      x-text="minutes"></b>
    min
  </span>
</div>
