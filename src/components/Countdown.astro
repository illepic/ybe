---
interface Props {
  targetDate: string; // ISO 8601, e.g. '2026-06-20T09:00:00-07:00'
}

const { targetDate } = Astro.props;
---

<div
  x-data={`countdown('${targetDate}')`}
  class="flex justify-center gap-6 mt-8 text-[0.78rem] font-medium tracking-[0.12em] uppercase text-muted"
>
  <span>
    <b
      class="block font-display text-[2rem] tracking-[0.04em] leading-none mb-[0.2rem] text-amber"
      x-text="days"></b>
    days
  </span>
  <span>
    <b
      class="block font-display text-[2rem] tracking-[0.04em] leading-none mb-[0.2rem] text-cyan"
      x-text="hours"></b>
    hrs
  </span>
  <span>
    <b
      class="block font-display text-[2rem] tracking-[0.04em] leading-none mb-[0.2rem] text-pink"
      x-text="minutes"></b>
    min
  </span>
</div>
