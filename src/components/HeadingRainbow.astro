---
interface Props {
  size?: 'xl' | 'lg';
  as?: 'h1' | 'h2';
  reveal?: boolean;
  class?: string;
}

const { size = 'lg', as: Tag = 'h2', reveal = true, class: className = '' } = Astro.props;

const sizeClasses: Record<string, string> = {
  xl: 'text-[clamp(4.5rem,16vw,11rem)] mb-2',
  lg: 'text-[clamp(3rem,9vw,7rem)] mb-4',
};
---

<Tag
  class:list={[
    'font-display tracking-[0.03em] leading-display font-bold',
    'gradient-rainbow-text',
    'drop-shadow-[2px_4px_12px_rgba(0,0,0,0.6)]',
    sizeClasses[size],
    reveal && 'reveal',
    className,
  ]}
>
  <slot />
</Tag>
