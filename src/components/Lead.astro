---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<p
  class:list={[
    'lead',
    'text-shadow-lg',
    'text-[clamp(1rem,2.5vw,1.2rem)]',
    'text-text',
    'max-w-xl',
    'mt-5',
    'mx-auto',
    'mb-10',
    'leading-[1.7]',
    className,
  ]}
>
  <slot />
</p>
