---
// A "How to get there" origin button. Lives inside an x-data="gettingThere"
// scope; clicking selects the route (Alpine) which dispatches `route:show`.
interface Props {
  id: string;
  label: string;
}

const { id, label } = Astro.props;
---

<button
  type="button"
  class="cursor-pointer rounded-sm border border-white/15 bg-white/5 px-3 py-1.5 text-sm font-semibold text-stone-100 transition-colors hover:bg-white/10 aria-pressed:border-amber-600 aria-pressed:bg-amber-700"
  @click={`select('${id}')`}
  aria-pressed="false"
  :aria-pressed={`(selected === '${id}').toString()`}
>
  {label}
</button>
