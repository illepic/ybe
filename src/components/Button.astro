---
interface Props {
  href?: string;
  variant?: 'fire' | 'amber' | 'ghost' | 'logo';
  target?: string;
  rel?: string;
  class?: string;
}

const { href, variant = 'fire', target, rel, class: className = '' } = Astro.props;

const base = [
  'btn',
  'inline-flex items-center gap-1.5',
  'font-body text-sm font-semibold tracking-widest uppercase no-underline',
  'rounded-sm border-2',
  'transition hover:-translate-y-0.5 hover:opacity-90',
  'w-full justify-center md:w-auto',
];

const variants: Record<string, string[]> = {
  fire: [
    ...base,
    'px-10 py-4',
    'bg-amber-700 text-stone-100 border-transparent hover:bg-amber-600',
  ],
  amber: [
    ...base,
    'px-10 py-4',
    'bg-amber-500 text-stone-950 border-transparent hover:bg-amber-400',
  ],
  ghost: [...base, 'px-10 py-4', 'border-stone-100/70 text-stone-100 hover:bg-stone-100/10'],
  logo: [...base, 'px-10 py-2.5 gap-3', 'border-stone-100/70 text-stone-100 hover:bg-stone-100/10'],
};
---

<a href={href} class:list={[...variants[variant], className]} {target} {rel}>
  <slot name="icon-left" />
  <slot />
  <slot name="icon-right" />
</a>
