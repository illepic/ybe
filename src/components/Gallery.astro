---
import { X, ChevronLeft, ChevronRight } from 'lucide-astro';
---

<div x-data="photoGallery">
  <!-- Thumbnail grid: 2-up mobile, 3-up sm+ -->
  <div
    class="gallery__grid grid grid-cols-2 sm:grid-cols-3 gap-1.5 max-w-[640px] mx-auto mt-10"
  >
    <template x-for="(photo, i) in photos" :key="i">
      <button
        class="gallery__thumb block aspect-square overflow-hidden rounded cursor-pointer border-0 p-0 bg-white/5 group"
        @click="openAt(i)"
      >
        <img
          :src="photo.thumb"
          :alt="photo.caption"
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover transition-[transform,opacity] duration-300 ease group-hover:scale-105 group-hover:opacity-80 will-change-transform"
        />
      </button>
    </template>
  </div>

  <!-- Modal -->
  <div
    class="gallery__modal fixed inset-0 z-[500] flex items-center justify-center p-6 focus:outline-none"
    x-cloak
    x-show="isOpen"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    x-trap="isOpen"
    x-effect="isOpen && $nextTick(() => $refs.modal.focus())"
    x-ref="modal"
    role="dialog"
    aria-modal="true"
    aria-label="Photo gallery"
    tabindex="-1"
    @keydown.escape="close()"
    @keydown.arrow-left="prev()"
    @keydown.arrow-right="next()"
  >
    <!-- Backdrop -->
    <div
      class="gallery__backdrop absolute inset-0 bg-black/92 cursor-pointer"
      @click="close()"
    ></div>

    <!-- Frame -->
    <div
      class="gallery__frame relative z-[1] flex items-center max-w-[min(90vw,1100px)] max-h-[90vh]"
    >
      <!-- Spinner -->
      <div x-show="loading" class="absolute inset-0 flex items-center justify-center">
        <div class="w-10 h-10 rounded-full border-4 border-white/20 border-t-white/80 animate-spin"
        ></div>
      </div>

      <!-- Full image -->
      <img
        x-ref="fullImg"
        :src="photos[current].full"
        :alt="photos[current].caption"
        @load="onImageLoad()"
        :class="loading ? 'opacity-0' : 'opacity-100'"
        class="block max-w-full max-h-[90vh] object-contain rounded transition-opacity duration-300"
      />

      <!-- Close -->
      <button
        class="gallery__btn gallery__btn--close absolute top-[-48px] right-0 z-[2] flex items-center justify-center w-[42px] h-[42px] rounded-[2px] border border-white/20 bg-[rgba(10,8,6,0.7)] text-stone-100 cursor-pointer transition-colors duration-200 hover:bg-amber-700 hover:border-amber-700"
        @click="close()"
        aria-label="Close gallery"
      >
        <X size={18} strokeWidth={2} />
      </button>

      <!-- Prev -->
      <button
        class="gallery__btn gallery__btn--prev absolute left-[-52px] top-1/2 -translate-y-1/2 z-[2] flex items-center justify-center w-[42px] h-[42px] rounded-[2px] border border-white/20 bg-[rgba(10,8,6,0.7)] text-stone-100 cursor-pointer transition-colors duration-200 hover:bg-amber-700 hover:border-amber-700 sm:left-[-52px] sm:bottom-auto sm:top-1/2 sm:-translate-y-1/2 max-sm:left-0 max-sm:bottom-[-52px] max-sm:top-auto max-sm:translate-y-0"
        @click.stop="prev()"
        aria-label="Previous photo"
      >
        <ChevronLeft size={22} strokeWidth={2} />
      </button>

      <!-- Next -->
      <button
        class="gallery__btn gallery__btn--next absolute right-[-52px] top-1/2 -translate-y-1/2 z-[2] flex items-center justify-center w-[42px] h-[42px] rounded-[2px] border border-white/20 bg-[rgba(10,8,6,0.7)] text-stone-100 cursor-pointer transition-colors duration-200 hover:bg-amber-700 hover:border-amber-700 sm:right-[-52px] sm:bottom-auto sm:top-1/2 sm:-translate-y-1/2 max-sm:right-0 max-sm:bottom-[-52px] max-sm:top-auto max-sm:translate-y-0"
        @click.stop="next()"
        aria-label="Next photo"
      >
        <ChevronRight size={22} strokeWidth={2} />
      </button>
    </div>
  </div>
</div>
