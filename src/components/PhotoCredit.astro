---
interface Props {
  name: string;
  url?: string;
  label?: string; // defaults to "Photo:"
  source?: string; // e.g. "Unsplash"
}

const { name, url, label = 'Photo:', source } = Astro.props;
---

<cite class="not-italic text-xs tracking-[0.06em] text-stone-100/35 pointer-events-none">
  {label}
  {
    url ? (
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="underline underline-offset-2 pointer-events-auto transition-colors duration-200 hover:text-stone-100/70"
      >
        {name}
      </a>
    ) : (
      name
    )
  }
  {source && <> / {source}</>}
</cite>
