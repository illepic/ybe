---
interface Props {
  href: string;
  target?: string;
  rel?: string;
  class?: string;
}

const { href, target, rel, class: className = '' } = Astro.props;
---

<a
  {href}
  {target}
  {rel}
  class:list={[
    'text-amber-500',
    'underline',
    'decoration-amber-500/40',
    'underline-offset-2',
    'transition-colors',
    'duration-200',
    'hover:decoration-amber-500',
    className,
  ]}
>
  <slot />
</a>
