---
import Accordion from './starwind/accordion/Accordion.astro';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<Accordion
  class:list={[
    'max-w-[720px]',
    'mx-auto',
    'text-left',
    'bg-black/65',
    'border',
    'border-white/10',
    'rounded',
    'px-8',
    className,
  ]}
>
  <slot />
</Accordion>
