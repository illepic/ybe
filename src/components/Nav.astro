---
import { ArrowRight } from 'lucide-astro';

interface Props {
  reg: string;
  dateShort: string;
}

const { reg, dateShort } = Astro.props;
---

<nav
  id="nav"
  x-data="{ scrolled: false }"
  @scroll.window.passive="scrolled = window.scrollY > 50"
  :class="{ 'bg-[rgba(10,8,6,0.9)] [backdrop-filter:blur(10px)] [-webkit-backdrop-filter:blur(10px)]': scrolled }"
  class="fixed inset-x-0 top-0 z-[200] flex items-center justify-between
         px-4 py-[0.4rem]
         md:px-8 md:py-3
         transition-[background,backdrop-filter] duration-[350ms] ease-linear"
>
  <a href="#hero">
    <img
      src="/logo.png"
      alt="Yacolt Burn Experience"
      width="2796"
      height="2743"
      class="block h-11 w-auto md:h-[70px]"
    />
  </a>
  <a
    href={reg}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-[0.35rem] rounded-[2px]
           bg-accent px-[1.3rem] py-[0.55rem]
           text-[0.8rem] font-semibold tracking-[0.1em] uppercase no-underline text-text
           transition-colors duration-200 hover:bg-[#df6322]"
  >
    Register <ArrowRight size={14} strokeWidth={2.5} />
    {dateShort}
  </a>
</nav>
