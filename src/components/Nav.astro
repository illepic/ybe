---
import { Flame } from 'lucide-astro';

interface Props {
  reg: string;
  dateShort: string;
  datetime: string;
}

const { reg, dateShort, datetime } = Astro.props;
---

<nav
  id="nav"
  x-data="{ scrolled: false }"
  @scroll.window.passive="scrolled = window.scrollY > 50"
  :class="{ 'bg-black/90 backdrop-blur-md': scrolled }"
  class="fixed inset-x-0 top-0 z-200 flex items-center justify-between
         px-4 py-1.5
         md:px-8 md:py-3
         transition duration-300 ease-linear"
>
  <a href="#hero">
    <img
      src="/logo.png"
      alt="Yacolt Burn Experience"
      width="2796"
      height="2743"
      class="block h-11 w-auto md:h-20"
    />
  </a>
  <a
    href={reg}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-1.5 rounded-xs
           bg-amber-700 px-5 py-2
           text-sm font-semibold tracking-widest uppercase no-underline text-stone-100
           transition-colors duration-200 hover:bg-amber-600"
  >
    Register <Flame size={14} strokeWidth={2.5} />
    <time datetime={datetime}>{dateShort}</time>
  </a>
</nav>
