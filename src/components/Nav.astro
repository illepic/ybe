---
import { Flame } from 'lucide-astro';

interface Props {
  reg: string;
  dateShort: string;
  datetime: string;
}

const { reg, dateShort, datetime } = Astro.props;

const IS_DEV = import.meta.env.DEV;
const logoSrc = IS_DEV
  ? '/logo.png'
  : `/.netlify/images?${new URLSearchParams({ url: '/logo.png', format: 'webp', w: '160', h: '160' })}`;
const logoSrcset = IS_DEV
  ? undefined
  : [
      `/.netlify/images?${new URLSearchParams({ url: '/logo.png', format: 'webp', w: '90', h: '90' })} 90w`,
      `/.netlify/images?${new URLSearchParams({ url: '/logo.png', format: 'webp', w: '160', h: '160' })} 160w`,
    ].join(', ');
---

<nav
  id="nav"
  x-data="{ scrolled: false }"
  @scroll.window.passive="scrolled = window.scrollY > 50"
  :class="{ 'bg-black/90 backdrop-blur-md': scrolled, 'opacity-0 pointer-events-none': $store.ui.galleryOpen }"
  class="fixed inset-x-0 top-0 z-200 flex items-center justify-between
         px-4 py-1.5
         md:px-8 md:py-3
         transition duration-300 ease-linear"
>
  <a href="#hero">
    <img
      src={logoSrc}
      srcset={logoSrcset}
      sizes="(min-width: 769px) 80px, 44px"
      alt="Yacolt Burn Experience"
      width="2796"
      height="2743"
      class="block h-11 w-auto md:h-20"
    />
  </a>
  <a
    href={reg}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-1.5 rounded-xs
           bg-amber-700 px-5 py-2
           text-sm font-semibold tracking-widest uppercase no-underline text-stone-100
           transition-colors duration-200 hover:bg-amber-600"
  >
    Register <Flame size={14} strokeWidth={2.5} />
    <time datetime={datetime}>{dateShort}</time>
  </a>
</nav>
