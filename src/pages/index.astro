---
import '../styles/tailwind.css';
import {
  ArrowDown,
  ArrowRight,
  ArrowUp,
  ArrowUpRight,
  Bike,
  CalendarDays,
  CheckCircle,
  Flame,
  ChevronDown,
  ChevronLeft,
  ChevronRight,
  Clock,
  MapPin,
  Medal,
  Minus,
  Package,
  Plus,
  Tag,
  Ticket,
  Users,
  X,
} from 'lucide-astro';

// ─── UPDATE THESE EACH YEAR ───────────────────────────────────────────────
const EVENT = {
  year: 2026,
  name: 'Yacolt Burn Experience 2026',
  date: 'June 20, 2026',
  dateShort: 'June 20',
  dateDay: 'Saturday, June 20, 2026',
  startTime: '9:00 AM',
  endTime: '4:00 PM',
  deadline: 'June 19th',
  isoStart: '2026-06-20T09:00:00-07:00',
  isoEnd: '2026-06-20T16:00:00-07:00',
  capacity: 299,
  priceMember: 35,
  priceGuest: 60,
  priceDayOf: 70,
};

const REG =
  'https://www.evergreenmtb.org/component/civicrm?task=civicrm/event/info&reset=1&id=5398';
const SITE = import.meta.env.SITE ?? 'https://yacoltburn.bike';

// Netlify Image CDN helper — transforms on deploy, raw path in local dev
const IS_DEV = import.meta.env.DEV;
const cdn = (path: string, params: Record<string, string> = {}) => {
  if (IS_DEV) return path;
  const p = new URLSearchParams({ url: path, format: 'webp', ...params });
  return `/.netlify/images?${p}`;
};

const POSTER = cdn('/photos/poster.jpg', { w: '1920', q: '85' });

// og:image — absolute URL, JPG (not WebP), standard portrait crop
const OG_IMAGE = `${SITE}/.netlify/images?url=/photos/poster.jpg&w=800&format=jpg&q=85`;

const IMG = {
  legend: cdn('/photos/pnw-forest-misty.jpg', { w: '1920', q: '80' }),
  ride: cdn('/photos/mtb-trail-forest.jpg', { w: '1920', q: '80' }),
  gallery: cdn('/photos/bikes-parked.jpg', { w: '1920', q: '80' }),
  details: cdn('/photos/hood.jpg', { w: '1920', q: '80' }),
  quote: cdn('/photos/trail-building.jpg', { w: '1920', q: '80' }),
  faq: cdn('/photos/hanging-bike.jpg', { w: '1920', q: '80' }),
  sponsors: cdn('/photos/forest-path.jpg', { w: '1920', q: '80' }),
  cta: cdn('/photos/mtb-sunset.jpg', { w: '1920', q: '80' }),
};

const JSON_LD = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SportsEvent',
  name: EVENT.name,
  description:
    'A full-day mountain bike shuttle event in the Yacolt Burn State Forest, southwest Washington.',
  startDate: EVENT.isoStart,
  endDate: EVENT.isoEnd,
  url: SITE,
  image: OG_IMAGE,
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  location: {
    '@type': 'Place',
    name: 'Yacolt Burn Trailhead',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Yacolt',
      addressRegion: 'WA',
      postalCode: '98675',
      addressCountry: 'US',
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: 45.7309,
      longitude: -122.303,
    },
  },
  organizer: {
    '@type': 'Organization',
    name: 'Evergreen Mountain Bike Alliance Southwest Chapter',
    url: 'https://www.evergreenmtb.org/chapters/southwest',
  },
  offers: {
    '@type': 'Offer',
    price: String(EVENT.priceMember),
    priceCurrency: 'USD',
    validFrom: '2026-01-01',
    validThrough: `${EVENT.year}-06-19`,
    url: 'https://www.evergreenmtb.org/component/civicrm?task=civicrm/event/info&reset=1&id=5398',
    availability: 'https://schema.org/LimitedAvailability',
  },
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{EVENT.name}</title>
    <meta
      name="description"
      content={`A full-day shuttle MTB event in the Yacolt Burn State Forest, southwest Washington. ${EVENT.date}.`}
    />

    <!-- Canonical & OG -->
    <link rel="canonical" href={SITE} />
    <meta name="theme-color" content="#100e0c" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={SITE} />
    <meta property="og:title" content={EVENT.name} />
    <meta
      property="og:description"
      content={`A full-day shuttle MTB event in the Yacolt Burn State Forest, southwest Washington. ${EVENT.date}.`}
    />
    <meta property="og:image" content={OG_IMAGE} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={EVENT.name} />
    <meta
      name="twitter:description"
      content={`A full-day shuttle MTB event in the Yacolt Burn State Forest, southwest Washington. ${EVENT.date}.`}
    />
    <meta name="twitter:image" content={OG_IMAGE} />

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Preload LCP image -->
    <link rel="preload" as="image" href={POSTER} fetchpriority="high" />

    <!-- DNS prefetch for external links -->
    <link rel="dns-prefetch" href="https://maps.app.goo.gl" />
    <link rel="dns-prefetch" href="https://www.trailforks.com" />
    <link rel="dns-prefetch" href="https://www.evergreenmtb.org" />

    <!-- JSON-LD Event schema -->
    <script type="application/ld+json" set:html={JSON_LD} />
  </head>
  <body>
    <!-- Skip link for keyboard/screenreader users -->
    <a href="#experience" class="skip-link">Skip to content</a>

    <!-- NAV -->
    <nav
      id="nav"
      x-data="{ scrolled: false }"
      @scroll.window.passive="scrolled = window.scrollY > 50"
      :class="{ 'nav--scrolled': scrolled }"
    >
      <a href="#hero" class="nav__brand">
        <img src="/logo.png" alt="Yacolt Burn Experience" width="2796" height="2743" />
      </a>
      <a href={REG} class="nav__cta" target="_blank" rel="noopener noreferrer"
        >Register <ArrowRight size={14} strokeWidth={2.5} /> {EVENT.dateShort}</a
      >
    </nav>

    <!-- ── 1 · HERO ── -->
    <section id="hero" class="panel panel--dark" style={`background-image: url('${POSTER}')`}>
      <div class="panel__inner">
        <span class="hero__datebadge"
          >{EVENT.date} &nbsp;·&nbsp; <a
            href="https://maps.app.goo.gl/fafFzUThcHkEMmTdA"
            class="loc"
            target="_blank"
            rel="noopener noreferrer">Yacolt Burn, SW Washington</a
          ></span
        >
        <h1 class="heading--xl">Yacolt<br />Burn<br />Experience</h1>
        <p class="lead">
          A full-day shuttle event deep in the heart of<br />
          <strong
            ><a
              href="https://dnr.wa.gov/forest-and-trust-lands/yacolt-burn-state-forest"
              target="_blank"
              rel="noopener noreferrer">Yacolt Burn State Forest</a
            ></strong
          >.
        </p>
        <p class="hero__stat">
          <span>{EVENT.capacity} riders.</span>
          <span>All the trails.</span>
          <span>One day.</span>
        </p>
        <div class="btn__group">
          <a href={REG} class="btn btn--fire" target="_blank" rel="noopener noreferrer"
            ><Ticket size={16} strokeWidth={2} /> Register Now</a
          >
          <a href="#experience" class="btn btn--ghost"
            >What to Expect <ChevronDown size={15} strokeWidth={2} /></a
          >
        </div>
        <div x-data="countdown" class="hero__countdown">
          <span><b x-text="days"></b> days</span>
          <span><b x-text="hours"></b> hrs</span>
          <span><b x-text="minutes"></b> min</span>
        </div>
      </div>
      <cite class="photo-credit"
        >Art by <a href="https://kathrynjaspersonart.com/" target="_blank" rel="noopener noreferrer"
          >Kathryn Jasperson</a
        ></cite
      >
    </section>

    <!-- ── 2 · THE EXPERIENCE ── -->
    <section
      id="experience"
      class="panel panel--dark"
      style={`background-image: url('${IMG.ride}')`}
    >
      <div class="panel__inner">
        <img
          src="/logo.png"
          alt="Yacolt Burn Experience"
          style="height: 120px; width: auto; display: block; margin: 0 auto 1.5rem;"
        />
        <span class="eyebrow">The Event</span>
        <h2 class="heading--lg reveal">The Full Day</h2>
        <span class="rule"></span>
        <p class="lead">
          All-day shuttles. Demo bikes. Food. Trails that took decades to build. Yours for one day.
        </p>
        <p>
          YBE runs 9am to 4pm. Shuttles load at the <a
            href="https://maps.app.goo.gl/fafFzUThcHkEMmTdA"
            class="loc"
            target="_blank"
            rel="noopener noreferrer">lower Yacolt Burn Trailhead</a
          > and drop riders at <a
            href="https://www.trailforks.com/region/yacolt-burn-state-forest/?activitytype=1&z=15.8&lat=45.73092&lon=-122.30301&content=trails,labels,region,poi,directory,polygon,waypoint,nst,routes_featured"
            target="_blank"
            rel="noopener noreferrer">Five Corners</a
          >, gateway to the upper trail system. Ride down. Load back up. Repeat. There are rumors
          shuttles may go all the way to <a
            href="https://www.trailforks.com/region/yacolt-burn-state-forest/?activitytype=1&z=16.0&lat=45.71673&lon=-122.29648&content=trails,labels,region,poi,directory,polygon,waypoint,nst,routes_featured"
            target="_blank"
            rel="noopener noreferrer">The Towers</a
          >.
        </p>
        <p>
          The event caps at {EVENT.capacity} riders and sells out every single year, rain or shine. Demo
          fleets from Norco and Propain are on-site. Vendors, food, and raffles round out the day. There's
          even an organized youth ride for ages 3–12 and bike games for all levels.
        </p>
        <p>
          The trail system is anchored by four standouts: <a
            href="https://www.trailforks.com/trails/cold-creek/"
            target="_blank"
            rel="noopener noreferrer">Cold Creek</a
          >, wild and rooty and rocky with the occasional burst of flow; <a
            href="https://www.trailforks.com/trails/sixth-sense/"
            target="_blank"
            rel="noopener noreferrer">Sixth Sense</a
          >, hand-crafted and flowy with the best berms in the forest; <a
            href="https://www.trailforks.com/trails/murphy-s-grade-98596/"
            target="_blank"
            rel="noopener noreferrer">Murphy's Grade</a
          >, hand-built by Carson Storch with fast doubles and plenty of speed; and <a
            href="https://www.trailforks.com/trails/thrillium/"
            target="_blank"
            rel="noopener noreferrer">Thrillium</a
          >, the sender: big, fast, and full of gnarly tabletops.
        </p>
        <a href={REG} class="btn btn--amber" target="_blank" rel="noopener noreferrer"
          ><CheckCircle size={16} strokeWidth={2} /> Claim Your Spot</a
        >
      </div>
      <cite class="photo-credit"
        >Photo: <a
          href="https://unsplash.com/@timberfoster"
          target="_blank"
          rel="noopener noreferrer">Tim Foster</a
        > / Unsplash</cite
      >
    </section>

    <!-- ── 3 · DETAILS ── -->
    <section
      id="details"
      class="panel panel--dark panel--deferred"
      style={`background-image: url('${IMG.details}')`}
    >
      <div class="panel__inner">
        <span class="eyebrow">{EVENT.date}</span>
        <h2 class="heading--lg reveal">Event Details</h2>
        <span class="rule"></span>

        <div class="detail-cards">
          <div class="detail-cards__card">
            <div class="detail-cards__label">
              <CalendarDays size={12} strokeWidth={2.5} /> Date & Time
            </div>
            <div class="detail-cards__value">
              {EVENT.dateDay}<br />{EVENT.startTime} – {EVENT.endTime}
            </div>
          </div>
          <div class="detail-cards__card">
            <div class="detail-cards__label"><MapPin size={12} strokeWidth={2.5} /> Location</div>
            <div class="detail-cards__value">
              <a
                href="https://maps.app.goo.gl/fafFzUThcHkEMmTdA"
                class="loc"
                target="_blank"
                rel="noopener noreferrer">Yacolt Burn Trailhead<br />Southwest Washington</a
              ><br /><small>Park on the west side of the road</small>
            </div>
          </div>
          <div class="detail-cards__card">
            <div class="detail-cards__label">
              <Package size={12} strokeWidth={2.5} /> What's Included
            </div>
            <div class="detail-cards__value">
              All-day shuttles<br />Demo bikes (Norco · Propain)<br />Food · Raffles · Vendors<br
              /><small>Youth ride ages 3–12</small>
            </div>
          </div>
          <div class="detail-cards__card">
            <div class="detail-cards__label"><Users size={12} strokeWidth={2.5} /> Capacity</div>
            <div class="detail-cards__value">
              {EVENT.capacity} riders max<br /><small>Sells out every year. Register early.</small>
            </div>
          </div>
        </div>

        <div class="details-arrow"><ArrowDown size={24} strokeWidth={2.5} /></div>
        <div class="pricing">
          <h3 class="heading--md" style="margin-bottom: 1.25rem; text-align: left;">
            Registration
          </h3>
          <div class="pricing__row">
            <div class="pricing__label">
              Members <a
                href="https://www.evergreenmtb.org/support-us/become-a-member"
                target="_blank"
                rel="noopener noreferrer"
                style="color: var(--c-accent); text-decoration: none; font-style: italic; font-size: 0.8rem;"
                >(join)</a
              ><small>Online · pre-event</small>
            </div>
            <div class="pricing__amount">${EVENT.priceMember}</div>
          </div>
          <div class="pricing__row">
            <div class="pricing__label">Non-Members <small>Online · pre-event</small></div>
            <div class="pricing__amount">${EVENT.priceGuest}</div>
          </div>
          <div class="pricing__row">
            <div class="pricing__label">Day-Of <small>All participants</small></div>
            <div class="pricing__amount">${EVENT.priceDayOf}</div>
          </div>
          <div style="margin-top: 1.5rem; text-align: center;">
            <a href={REG} class="btn btn--fire" target="_blank" rel="noopener noreferrer"
              >Register by {EVENT.deadline}</a
            >
          </div>
        </div>
      </div>
      <cite class="photo-credit">Photo by Todd McCarthy</cite>
    </section>

    <!-- ── 4 · GALLERY ── -->
    <section
      id="gallery"
      class="panel panel--dark panel--scroll panel--deferred"
      style={`background-image: url('${IMG.gallery}')`}
    >
      <div class="panel__inner">
        <span class="eyebrow">From the Trails</span>
        <h2 class="heading--lg reveal">See You Out There</h2>
        <span class="rule"></span>

        <!-- Replace Unsplash placeholders with real event photos in src/entrypoints/alpine.js -->
        <div x-data="photoGallery">
          <div class="gallery__grid">
            <template x-for="(photo, i) in photos" :key="i">
              <button class="gallery__thumb" @click="openAt(i)">
                <img :src="photo.thumb" :alt="photo.caption" loading="lazy" decoding="async" />
              </button>
            </template>
          </div>

          <div
            class="gallery__modal"
            x-cloak
            x-show="isOpen"
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            x-trap="isOpen"
            x-effect="isOpen && $nextTick(() => $refs.modal.focus())"
            x-ref="modal"
            role="dialog"
            aria-modal="true"
            aria-label="Photo gallery"
            tabindex="-1"
            @keydown.escape="close()"
            @keydown.arrow-left="prev()"
            @keydown.arrow-right="next()"
          >
            <div class="gallery__backdrop" @click="close()"></div>
            <div class="gallery__frame">
              <img :src="photos[current].full" :alt="photos[current].caption" />
              <button
                class="gallery__btn gallery__btn--close"
                @click="close()"
                aria-label="Close gallery"><X size={18} strokeWidth={2} /></button
              >
              <button
                class="gallery__btn gallery__btn--prev"
                @click.stop="prev()"
                aria-label="Previous photo"><ChevronLeft size={22} strokeWidth={2} /></button
              >
              <button
                class="gallery__btn gallery__btn--next"
                @click.stop="next()"
                aria-label="Next photo"><ChevronRight size={22} strokeWidth={2} /></button
              >
            </div>
          </div>
        </div>
      </div>
      <cite class="photo-credit"
        >Photo: <a href="https://unsplash.com/@seanbenesh" target="_blank" rel="noopener noreferrer"
          >Sean Benesh</a
        > / Unsplash</cite
      >
    </section>

    <!-- ── 5 · LEGEND ── -->
    <section
      id="legend"
      class="panel panel--deferred"
      style={`background-image: url('${IMG.legend}')`}
    >
      <div class="panel__inner">
        <span class="eyebrow">A Place With History</span>
        <h2 class="heading--lg reveal">Born From Fire</h2>
        <span class="rule"></span>
        <p class="lead">
          The Klickitat word <em>Yacolt</em> means "haunted valley," a place of legend long before a single
          trail was ever cut.
        </p>
        <p>
          On September 11, 1902, a firestorm swept through southwest Washington. Within 36 hours it
          consumed 238,920 acres, killed 38 people, rained ash on Portland, and triggered street
          lamps to switch on at noon in Seattle. The town of Yacolt nearly vanished before the wind
          direction changed.
        </p>
        <p>
          What followed was one of Washington's great rehabilitation stories: Civilian Conservation
          Corps crews in the 1930s, decades of DNR replanting, and a generation of mountain bikers
          who saw something in those old logging roads in the late 1990s and started riding them.
          The Yacolt Burn Experience is the product of all of it.
        </p>
        <a
          href="https://www.evergreenmtb.org/blog/yacolt-burn-experience-history"
          target="_blank"
          rel="noopener noreferrer"
          style="display: inline-block; margin-top: 2rem; color: var(--c-accent); text-decoration: underline; text-underline-offset: 3px; font-size: 0.9rem;"
          >Read More</a
        >
      </div>
      <cite class="photo-credit"
        >Photo: <a
          href="https://unsplash.com/@sebastian_unrau"
          target="_blank"
          rel="noopener noreferrer">Sebastian Unrau</a
        > / Unsplash</cite
      >
    </section>

    <!-- ── 5 · PULL QUOTE ── -->
    <section
      id="trails"
      class="panel panel--dark panel--deferred"
      style={`background-image: url('${IMG.quote}')`}
    >
      <div class="panel__inner">
        <p class="pullquote">"The trails you love<br /><em>are not free.</em>"</p>
        <p class="lead">
          Every trail in the Yacolt Burn exists because regular people showed up on a Saturday with
          hand tools and did the work. The Evergreen Mountain Bike Alliance is how that keeps
          happening.
        </p>
        <a
          href="https://www.evergreenmtb.org"
          class="btn btn--ghost btn--logo"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span>Join <ArrowRight size={13} strokeWidth={2.5} /></span>
          <img src="/sponsors/evergreen-mtb.png" alt="Evergreen Mountain Bike Alliance" />
        </a>
      </div>
      <cite class="photo-credit"
        >Photo: <a
          href="https://unsplash.com/@timberfoster"
          target="_blank"
          rel="noopener noreferrer">Tim Foster</a
        > / Unsplash</cite
      >
    </section>

    <!-- ── 6 · FAQ ── -->
    <section id="faq" class="panel panel--deferred" style={`background-image: url('${IMG.faq}')`}>
      <div class="panel__inner">
        <span class="eyebrow">Questions</span>
        <h2 class="heading--lg reveal">FAQ</h2>
        <span class="rule"></span>
        <div class="faq">
          <div class="faq__item" x-data="{ open: false }">
            <button class="faq__question" @click="open = !open" :aria-expanded="open.toString()">
              What skill level do I need?
              <span class="faq__icon" aria-hidden="true"
                ><span x-show="!open"><Plus size={16} strokeWidth={2.5} /></span><span x-show="open"
                  ><Minus size={16} strokeWidth={2.5} /></span
                ></span
              >
            </button>
            <div x-show="open" x-collapse>
              <p class="faq__answer">
                The upper system accessed from Five Corners is intermediate to advanced terrain. The
                event welcomes all riders though, including a dedicated youth ride for ages 3–12.
                Volunteers and the community are there to help you find your line.
              </p>
            </div>
          </div>
          <div class="faq__item" x-data="{ open: false }">
            <button class="faq__question" @click="open = !open" :aria-expanded="open.toString()">
              Does it sell out?
              <span class="faq__icon" aria-hidden="true"
                ><span x-show="!open"><Plus size={16} strokeWidth={2.5} /></span><span x-show="open"
                  ><Minus size={16} strokeWidth={2.5} /></span
                ></span
              >
            </button>
            <div x-show="open" x-collapse>
              <p class="faq__answer">
                Every single year. Space is capped at {EVENT.capacity} riders. Register online by {
                  EVENT.deadline
                } to lock in your spot and your best rate.
              </p>
            </div>
          </div>
          <div class="faq__item" x-data="{ open: false }">
            <button class="faq__question" @click="open = !open" :aria-expanded="open.toString()">
              What if it rains?
              <span class="faq__icon" aria-hidden="true"
                ><span x-show="!open"><Plus size={16} strokeWidth={2.5} /></span><span x-show="open"
                  ><Minus size={16} strokeWidth={2.5} /></span
                ></span
              >
            </button>
            <div x-show="open" x-collapse>
              <p class="faq__answer">
                The event runs rain or shine. It's historically 50/50 on weather. This is the
                Pacific Northwest. Pack a rain shell, bring layers, and embrace it.
              </p>
            </div>
          </div>
          <div class="faq__item" x-data="{ open: false }">
            <button class="faq__question" @click="open = !open" :aria-expanded="open.toString()">
              Do I need to be an Evergreen member?
              <span class="faq__icon" aria-hidden="true"
                ><span x-show="!open"><Plus size={16} strokeWidth={2.5} /></span><span x-show="open"
                  ><Minus size={16} strokeWidth={2.5} /></span
                ></span
              >
            </button>
            <div x-show="open" x-collapse>
              <p class="faq__answer">
                Nope, everyone is welcome. Members save $25 on registration though, and your trails
                depend on the Evergreen Mountain Bike Alliance. Basic membership is $50/year and
                pays for itself at events like this.
              </p>
            </div>
          </div>
          <div class="faq__item" x-data="{ open: false }">
            <button class="faq__question" @click="open = !open" :aria-expanded="open.toString()">
              Can I try a demo bike?
              <span class="faq__icon" aria-hidden="true"
                ><span x-show="!open"><Plus size={16} strokeWidth={2.5} /></span><span x-show="open"
                  ><Minus size={16} strokeWidth={2.5} /></span
