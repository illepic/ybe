---
const REG = "https://www.evergreenmtb.org/component/civicrm?task=civicrm/event/info&reset=1&id=5398";

// Netlify Image CDN helper — transforms on deploy, raw path in local dev
const IS_DEV = import.meta.env.DEV;
const cdn = (path: string, params: Record<string, string> = {}) => {
  if (IS_DEV) return path;
  const p = new URLSearchParams({ url: path, format: 'webp', ...params });
  return `/.netlify/images?${p}`;
};

const POSTER = cdn('/photos/poster.jpg', { w: '1920', q: '85' });

const IMG = {
  legend:   cdn('/photos/pnw-forest-misty.jpg',  { w: '1920', q: '80' }),
  ride:     cdn('/photos/mtb-trail-forest.jpg',  { w: '1920', q: '80' }),
  details:  cdn('/photos/mountain-landscape.jpg', { w: '1920', q: '80' }),
  quote:    cdn('/photos/trail-building.jpg',     { w: '1920', q: '80' }),
  faq:      cdn('/photos/forest-light.jpg',       { w: '1920', q: '80' }),
  sponsors: cdn('/photos/forest-path.jpg',        { w: '1920', q: '80' }),
  cta:      cdn('/photos/mtb-sunset.jpg',         { w: '1920', q: '80' }),
};
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Yacolt Burn Experience 2026</title>
  <meta name="description" content="A full-day shuttle MTB event in the Yacolt Burn State Forest, southwest Washington. June 20, 2026." />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Yacolt Burn Experience 2026" />
  <meta property="og:description" content="A full-day shuttle MTB event in the Yacolt Burn State Forest, southwest Washington. June 20, 2026." />
  <meta property="og:image" content={POSTER} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Yacolt Burn Experience 2026" />
  <meta name="twitter:description" content="A full-day shuttle MTB event in the Yacolt Burn State Forest, southwest Washington. June 20, 2026." />
  <meta name="twitter:image" content={POSTER} />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- NAV -->
  <nav id="nav" x-data="{ scrolled: false }" @scroll.window.passive="scrolled = window.scrollY > 50" :class="{ scrolled }">
    <a href="#hero" class="nav-brand">
      <img src="/logo.png" alt="Yacolt Burn Experience" />
    </a>
    <a href={REG} class="nav-cta" target="_blank" rel="noopener noreferrer">Register → June 20</a>
  </nav>

  <!-- ── 1 · HERO ── -->
  <section id="hero" class="panel dark" style={`background-image: url('${POSTER}')`}>
    <div class="inner">
      <span class="datebadge">June 20, 2026 &nbsp;·&nbsp; <a href="https://maps.app.goo.gl/fafFzUThcHkEMmTdA" class="loc" target="_blank" rel="noopener noreferrer">Yacolt Burn, SW Washington</a></span>
      <h1 class="t-xl">Yacolt<br />Burn<br />Experience</h1>
      <p class="lead">
        A full-day shuttle event deep in the heart of<br />
        <strong><a href="https://dnr.wa.gov/forest-and-trust-lands/yacolt-burn-state-forest" target="_blank" rel="noopener noreferrer">Yacolt Burn State Forest</a></strong>.
      </p>
      <p class="hero-stat">
        <span>299 riders.</span>
        <span>All the trails.</span>
        <span>One day.</span>
      </p>
      <div class="btn-group">
        <a href={REG} class="btn btn-fire" target="_blank" rel="noopener noreferrer">Register Now</a>
        <a href="#experience" class="btn btn-ghost">What to Expect</a>
      </div>
    </div>
  </section>

  <!-- ── 2 · THE EXPERIENCE ── -->
  <section id="experience" class="panel dark" style={`background-image: url('${IMG.ride}')`}>
    <div class="inner">
      <img src="/logo.png" alt="Yacolt Burn Experience" style="height: 120px; width: auto; display: block; margin: 0 auto 1.5rem;" />
      <span class="eyebrow">The Event</span>
      <h2 class="t-lg">The Full Day</h2>
      <span class="rule"></span>
      <p class="lead">All-day shuttles. Demo bikes. Food. Trails that took decades to build. Yours for one day.</p>
      <p>YBE runs 9am to 4pm. Shuttles load at the <a href="https://maps.app.goo.gl/fafFzUThcHkEMmTdA" class="loc" target="_blank" rel="noopener noreferrer">lower Yacolt Burn Trailhead</a> and drop riders at <a href="https://www.trailforks.com/region/yacolt-burn-state-forest/?activitytype=1&z=15.8&lat=45.73092&lon=-122.30301&content=trails,labels,region,poi,directory,polygon,waypoint,nst,routes_featured" target="_blank" rel="noopener noreferrer">Five Corners</a>, gateway to the upper trail system. Ride down. Load back up. Repeat. There are rumors shuttles may go all the way to <a href="https://www.trailforks.com/region/yacolt-burn-state-forest/?activitytype=1&z=16.0&lat=45.71673&lon=-122.29648&content=trails,labels,region,poi,directory,polygon,waypoint,nst,routes_featured" target="_blank" rel="noopener noreferrer">The Towers</a>.</p>
      <p>The event caps at 299 riders and sells out every single year, rain or shine. Demo fleets from Propain and Norco are on-site. Vendors, food, and raffles round out the day. There's even an organized youth ride for ages 3–12 and bike games for all levels.</p>
      <a href={REG} class="btn btn-amber" target="_blank" rel="noopener noreferrer">Claim Your Spot</a>
    </div>
  </section>

  <!-- ── 3 · DETAILS ── -->
  <section id="details" class="panel dark" style={`background-image: url('${IMG.details}')`}>
    <div class="inner">
      <span class="eyebrow">June 20, 2026</span>
      <h2 class="t-lg">Event Details</h2>
      <span class="rule"></span>

      <div class="cards">
        <div class="card">
          <div class="card-label">Date & Time</div>
          <div class="card-value">Saturday, June 20, 2026<br />9:00 AM – 4:00 PM</div>
        </div>
        <div class="card">
          <div class="card-label">Location</div>
          <div class="card-value"><a href="https://maps.app.goo.gl/fafFzUThcHkEMmTdA" class="loc" target="_blank" rel="noopener noreferrer">Yacolt Burn Trailhead<br />Southwest Washington</a><br /><small>Park on the west side of the road</small></div>
        </div>
        <div class="card">
          <div class="card-label">What's Included</div>
          <div class="card-value">All-day shuttles<br />Demo bikes (Propain · Norco)<br />Food · Raffles · Vendors<br /><small>Youth ride ages 3–12</small></div>
        </div>
        <div class="card">
          <div class="card-label">Capacity</div>
          <div class="card-value">299 riders max<br /><small>Sells out every year. Register early.</small></div>
        </div>
      </div>

      <div class="price-box">
        <h3 class="t-md" style="margin-bottom: 1.25rem; text-align: left;">Registration</h3>
        <div class="price-row">
          <div class="price-label">Members <a href="https://www.evergreenmtb.org/support-us/become-a-member" target="_blank" rel="noopener noreferrer" style="color: var(--c-accent); text-decoration: none; font-style: italic; font-size: 0.8rem;">(join)</a><small>Online · pre-event</small></div>
          <div class="price-num">$35</div>
        </div>
        <div class="price-row">
          <div class="price-label">Non-Members <small>Online · pre-event</small></div>
          <div class="price-num">$60</div>
        </div>
        <div class="price-row">
          <div class="price-label">Day-Of <small>All participants</small></div>
          <div class="price-num">$70</div>
        </div>
        <div style="margin-top: 1.5rem; text-align: center;">
          <a href={REG} class="btn btn-fire" target="_blank" rel="noopener noreferrer">Register by June 19th</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 4 · GALLERY ── -->
  <section id="gallery" class="panel dark" style={`background-image: url('${IMG.ride}')`}>
    <div class="inner">
      <span class="eyebrow">From the Trails</span>
      <h2 class="t-lg">See You Out There</h2>
      <span class="rule"></span>

      <!-- Replace Unsplash placeholders with real event photos in src/entrypoints/alpine.js -->
      <div x-data="photoGallery">
        <div class="gallery-grid">
          <template x-for="(photo, i) in photos" :key="i">
            <button class="gallery-thumb" @click="openAt(i)">
              <img :src="photo.thumb" :alt="photo.caption" loading="lazy" />
            </button>
          </template>
        </div>

        <div class="gallery-modal" x-cloak x-show="isOpen"
          x-transition:enter="transition ease-out duration-200"
          x-transition:enter-start="opacity-0"
          x-transition:enter-end="opacity-100"
          x-transition:leave="transition ease-in duration-150"
          x-transition:leave-start="opacity-100"
          x-transition:leave-end="opacity-0"
          x-ref="modal"
          x-effect="isOpen && $nextTick(() => $refs.modal.focus())"
          tabindex="-1"
          @keydown.escape="isOpen = false"
          @keydown.arrow-left="prev()"
          @keydown.arrow-right="next()">
          <div class="modal-backdrop" @click="isOpen = false"></div>
          <div class="modal-frame">
            <img :src="photos[current].full" :alt="photos[current].caption" />
            <button class="modal-btn modal-close" @click="isOpen = false">✕</button>
            <button class="modal-btn modal-prev" @click.stop="prev()">←</button>
            <button class="modal-btn modal-next" @click.stop="next()">→</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 5 · LEGEND ── -->
  <section id="legend" class="panel" style={`background-image: url('${IMG.legend}')`}>
    <div class="inner">
      <span class="eyebrow">A Place With History</span>
      <h2 class="t-lg">Born From Fire</h2>
      <span class="rule"></span>
      <p class="lead">The Klickitat word <em>Yacolt</em> means "haunted valley," a place of legend long before a single trail was ever cut.</p>
      <p>On September 11, 1902, a firestorm swept through southwest Washington. Within 36 hours it consumed 238,920 acres, killed 38 people, rained ash on Portland, and triggered street lamps to switch on at noon in Seattle. The town of Yacolt nearly vanished before the wind direction changed.</p>
      <p>What followed was one of Washington's great rehabilitation stories: Civilian Conservation Corps crews in the 1930s, decades of DNR replanting, and a generation of mountain bikers who saw something in those old logging roads in the late 1990s and started riding them. The Yacolt Burn Experience is the product of all of it.</p>
    </div>
  </section>

  <!-- ── 5 · PULL QUOTE ── -->
  <section id="trails" class="panel dark" style={`background-image: url('${IMG.quote}')`}>
    <div class="inner">
      <p class="pullquote">"The trails you love<br /><em>are not free.</em>"</p>
      <p class="lead">Every trail in the Yacolt Burn exists because regular people showed up on a Saturday with hand tools and did the work. The Evergreen Mountain Bike Alliance is how that keeps happening.</p>
      <a href="https://www.evergreenmtb.org" class="btn btn-ghost btn-logo" target="_blank" rel="noopener noreferrer">
        <span>Join</span>
        <img src="/sponsors/evergreen-mtb.png" alt="Evergreen Mountain Bike Alliance" />
      </a>
    </div>
  </section>

  <!-- ── 6 · FAQ ── -->
  <section id="faq" class="panel" style={`background-image: url('${IMG.faq}')`}>
    <div class="inner">
      <span class="eyebrow">Questions</span>
      <h2 class="t-lg">FAQ</h2>
      <span class="rule"></span>
      <div class="faq">
        <div class="faq-item">
          <div class="faq-q">What skill level do I need?</div>
          <p class="faq-a">The upper system accessed from Five Corners is intermediate to advanced terrain. The event welcomes all riders though, including a dedicated youth ride for ages 3–12. Volunteers and the community are there to help you find your line.</p>
        </div>
        <div class="faq-item">
          <div class="faq-q">Does it sell out?</div>
          <p class="faq-a">Every single year. Space is capped at 299 riders. Register online by June 19th to lock in your spot and your best rate.</p>
        </div>
        <div class="faq-item">
          <div class="faq-q">What if it rains?</div>
          <p class="faq-a">The event runs rain or shine. It's historically 50/50 on weather. This is the Pacific Northwest. Pack a rain shell, bring layers, and embrace it.</p>
        </div>
        <div class="faq-item">
          <div class="faq-q">Do I need to be an Evergreen member?</div>
          <p class="faq-a">Nope, everyone is welcome. Members save $25 on registration though, and your trails depend on the Evergreen Mountain Bike Alliance. Basic membership is $50/year and pays for itself at events like this.</p>
        </div>
        <div class="faq-item">
          <div class="faq-q">Can I try a demo bike?</div>
          <p class="faq-a">Yep. Propain and Norco both bring demo fleets to the event. Availability is first-come, first-served on the day.</p>
        </div>
        <div class="faq-item">
          <div class="faq-q">Where do I park?</div>
          <p class="faq-a"><a href="https://maps.app.goo.gl/fafFzUThcHkEMmTdA" class="loc" target="_blank" rel="noopener noreferrer">Yacolt Burn Trailhead</a>. Park on the west side of the road. It fills early, so plan to arrive by 8:30 AM.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 7 · SPONSORS ── -->
  <section id="sponsors" class="panel dark" style={`background-image: url('${IMG.sponsors}')`}>
    <div class="inner">
      <span class="eyebrow">Made Possible By</span>
      <h2 class="t-lg">2026 Sponsors</h2>
      <span class="rule"></span>
      <p class="lead">YBE exists because of this community of brands, shops, and people who show up every year to make it happen.</p>

      <div class="sponsor-tier">
        <div class="tier-label gold">Gold</div>
        <div class="sponsor-row">
          <div class="s-logo gold"><img src="/sponsors/norco.svg" alt="Norco" /></div>
        </div>
      </div>

      <div class="sponsor-tier">
        <div class="tier-label silver">Silver</div>
        <div class="sponsor-row">
          <div class="s-logo silver"><img src="/sponsors/propain.svg" alt="Propain Bikes" /></div>
          <div class="s-logo silver"><img src="/sponsors/pnw-components.png" alt="PNW Components" /></div>
          <div class="s-logo silver"><img src="/sponsors/crankbrothers.svg" alt="Crankbrothers" /></div>
          <div class="s-logo silver"><img src="/sponsors/cushcore.svg" alt="Cushcore" /></div>
          <span class="badge silver">Camas Bikes</span>
          <span class="badge silver">Formula 100</span>
          <div class="s-logo silver"><img src="/sponsors/evo.svg" alt="Evo Portland" /></div>
        </div>
      </div>

      <div class="sponsor-tier">
        <div class="tier-label bronze">Bronze</div>
        <div class="sponsor-row">
          <div class="s-logo bronze"><img src="/sponsors/spank.png" alt="Gravity Cartel / Spank" /></div>
          <span class="badge bronze">Red Bull</span>
          <div class="s-logo bronze"><img src="/sponsors/sram.svg" alt="SRAM" /></div>
          <div class="s-logo bronze"><img src="/sponsors/dt-swiss.svg" alt="DT Swiss" /></div>
          <span class="badge bronze">Kenda</span>
          <span class="badge bronze">All City Print</span>
          <span class="badge bronze">You Move Me</span>
          <span class="badge bronze">Pull Caffè Coffee Roasters</span>
          <span class="badge bronze">Frito Lay</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 8 · FINAL CTA ── -->
  <section id="register" class="panel dark" style={`background-image: url('${IMG.cta}')`}>
    <div class="inner">
      <span class="datebadge">June 20, 2026 &nbsp;·&nbsp; <a href="https://maps.app.goo.gl/fafFzUThcHkEMmTdA" class="loc" target="_blank" rel="noopener noreferrer">Yacolt Burn, SW Washington</a></span>
      <h2 class="t-xl">Register.<br />Ride.<br />Repeat.</h2>
      <span class="rule"></span>
      <p class="lead">One day. 299 riders. The entire Yacolt Burn trail system, shuttled all day, for the cost of a tank of gas. This is what community trail building looks like.</p>
      <a href={REG} class="btn btn-amber" target="_blank" rel="noopener noreferrer" style="font-size: 0.95rem; padding: 1.1rem 3.2rem;">Secure Your Spot</a>
    </div>
  </section>

  <footer>
    <p>Yacolt Burn Experience 2026 &nbsp;·&nbsp; Organized by the <a href="https://www.evergreenmtb.org/chapters/southwest" target="_blank" rel="noopener noreferrer">Evergreen Mountain Bike Alliance Southwest Chapter</a></p>
    <p style="margin-top: 0.4rem;"><a href="https://maps.app.goo.gl/fafFzUThcHkEMmTdA" class="loc" target="_blank" rel="noopener noreferrer">Yacolt Burn State Forest &nbsp;·&nbsp; Southwest Washington</a></p>
  </footer>


</body>

</html>

<style is:global>
/* ─── RESET & BASE ─── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --c-bg:      #100e0c;
      --c-accent:  #c8571b;
      --c-amber:   #e8a23a;
      --c-text:    #f0ece4;
      --c-muted:   #aba49a;
      --c-ol:      rgba(10, 8, 6, 0.62);
      --c-ol-dark: rgba(10, 8, 6, 0.80);
      --f-display: 'Bebas Neue', Impact, sans-serif;
      --f-body:    'Inter', system-ui, sans-serif;
    }
    html { scroll-behavior: smooth; }
    body {
      background: var(--c-bg);
      color: var(--c-text);
      font-family: var(--f-body);
      font-size: 1rem;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    a { color: inherit; }

    /* ─── NAV ─── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 200;
      padding: 0.75rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      transition: background 0.35s ease, backdrop-filter 0.35s ease;
    }
    nav.scrolled {
      background: rgba(10, 8, 6, 0.9);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }
    .nav-brand img  { height: 70px; display: block; width: auto; }
    .nav-brand span {
      font-family: var(--f-display);
      font-size: 1.5rem;
      letter-spacing: 0.06em;
      color: var(--c-text);
      text-decoration: none;
    }
    .nav-cta {
      display: inline-block;
      padding: 0.55rem 1.3rem;
      background: var(--c-accent);
      color: var(--c-text);
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      text-decoration: none;
      border-radius: 2px;
      transition: background 0.2s;
    }
    .nav-cta:hover { background: #df6322; }

    /* ─── PANELS ─── */
    .panel {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background-size: cover;
      background-attachment: fixed;
      background-position: center;
      background-repeat: no-repeat;
    }
    .panel::before {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--c-ol);
    }
    .panel.dark::before { background: var(--c-ol-dark); }

    .inner {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 860px;
      margin: 0 auto;
      padding: 7rem 2rem 5rem;
      text-align: center;
    }

    /* ─── TYPE SCALE ─── */
    h1, h2, h3 {
      font-family: var(--f-display);
      letter-spacing: 0.03em;
      line-height: 0.93;
      color: var(--c-text);
    }
    .eyebrow {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--c-accent);
      margin-bottom: 1rem;
    }
    .t-xl { font-size: clamp(4.5rem, 16vw, 11rem); margin-bottom: 0.5rem; }
    .t-lg { font-size: clamp(3rem, 9vw, 7rem);  margin-bottom: 1rem; }
    .t-md { font-size: clamp(1.6rem, 4vw, 2.6rem); margin-bottom: 0.75rem; }
    .lead {
      font-size: clamp(1rem, 2.5vw, 1.2rem);
      color: rgba(240,236,228,0.85);
      max-width: 600px;
      margin: 1.25rem auto 2.5rem;
      line-height: 1.7;
    }
    p {
      color: var(--c-muted);
      line-height: 1.85;
      margin-bottom: 1.2rem;
      max-width: 680px;
      margin-left: auto;
      margin-right: auto;
    }
    p:last-of-type { margin-bottom: 0; }

    /* ─── RULE ─── */
    .rule {
      display: block;
      width: 52px;
      height: 3px;
      background: var(--c-accent);
      margin: 1.5rem auto;
    }

    /* ─── BUTTONS ─── */
    .btn {
      display: inline-block;
      padding: 0.95rem 2.4rem;
      font-family: var(--f-body);
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      text-decoration: none;
      border-radius: 2px;
      transition: transform 0.15s ease, opacity 0.2s;
    }
    .btn:hover { transform: translateY(-2px); opacity: 0.9; }
    .btn-fire   { background: var(--c-accent); color: var(--c-text); }
    .btn-amber  { background: var(--c-amber);  color: #180e04; }
    .btn-ghost  { border: 2px solid rgba(240,236,228,0.7); color: var(--c-text); }
    .btn-ghost:hover { background: rgba(240,236,228,0.08); }
    .btn-logo {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      padding-top: 0.6rem;
      padding-bottom: 0.6rem;
    }
    .btn-logo span { font-size: 0.85rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; }
    .btn-logo img  { height: 68px; width: auto; opacity: 0.9; }
    .btn-group  { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
    .inner > .btn,
    .inner > .btn-group { margin-top: 2.5rem; }

    /* ─── HERO STAT LINE ─── */
    .hero-stat {
      font-family: var(--f-display);
      font-size: clamp(1.6rem, 5vw, 2.8rem);
      letter-spacing: 0.06em;
      line-height: 1;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.3rem 1.1rem;
      margin: 1.25rem auto 0;
      max-width: none;
    }
    .hero-stat span {
      color: var(--c-amber);
      opacity: 0;
      animation: fadeUp 0.55s ease forwards;
