---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import PhotoCredit from '../components/PhotoCredit.astro';
import HeadingRainbow from '../components/HeadingRainbow.astro';
import Nav from '../components/Nav.astro';
import Panel from '../components/Panel.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Button from '../components/Button.astro';
import Lead from '../components/Lead.astro';
import Rule from '../components/Rule.astro';
import Content from '../components/Content.astro';
import ContentLink from '../components/ContentLink.astro';
import Pricing from '../components/Pricing.astro';
import PricingRow from '../components/PricingRow.astro';
import DateLocation from '../components/DateLocation.astro';
import Faq from '../components/Faq.astro';
import FaqItem from '../components/FaqItem.astro';
import SponsorTier from '../components/SponsorTier.astro';
import Gallery from '../components/Gallery.astro';
import { GALLERY_PHOTOS } from '../data/gallery';
import { cdn } from '../lib/utils/cdn';
import Collapsible from '../components/starwind/collapsible/Collapsible.astro';
import CollapsibleContent from '../components/starwind/collapsible/CollapsibleContent.astro';
import CollapsibleTrigger from '../components/starwind/collapsible/CollapsibleTrigger.astro';
import Progress from '../components/starwind/progress/Progress.astro';
import Footer from '../components/Footer.astro';
import RevealObserver from '../components/RevealObserver.astro';
import GettingThereMap from '../components/GettingThereMap.astro';
import RouteButton from '../components/RouteButton.astro';
import { GETTING_THERE_ROUTES } from '../data/gettingThereRoutes';
import Alert from '../components/starwind/alert/Alert.astro';
import AlertTitle from '../components/starwind/alert/AlertTitle.astro';
import AlertDescription from '../components/starwind/alert/AlertDescription.astro';
import Card from '../components/starwind/card/Card.astro';
import CardHeader from '../components/starwind/card/CardHeader.astro';
import CardTitle from '../components/starwind/card/CardTitle.astro';
import CardContent from '../components/starwind/card/CardContent.astro';
import {
  ArrowDown,
  ArrowRight,
  ArrowUpRight,
  Bike,
  CalendarDays,
  CheckCircle,
  Flame,
  ChevronDown,
  Clock,
  MapPin,
  Medal,
  Minus,
  Package,
  Plus,
  Tag,
  Ticket,
  TriangleAlert,
  Users,
  X,
  SquareArrowOutUpRight,
} from 'lucide-astro';
import { getEntry } from 'astro:content';
import { formatInTimeZone } from 'date-fns-tz';

// ─── LOAD EVENT + SPONSOR DATA FROM CONTENT COLLECTIONS ──────────────────
const eventEntry = await getEntry('event', 'current');
const sponsorsEntry = await getEntry('sponsors', 'current');

if (!eventEntry || !sponsorsEntry) throw new Error('Missing content: event or sponsors');

const EVENT = eventEntry.data;
const REG = EVENT.reg;
const SITE = import.meta.env.SITE ?? 'https://yacoltburn.bike';

const DESCRIPTION = `A full-day shuttle MTB event in the Yacolt Burn State Forest, southwest Washington. ${EVENT.date}.`;

// "June 19th" for display — formatted in the event's timezone so a UTC build
// server doesn't roll a late-night Pacific deadline onto the next day.
const deadlineDay = formatInTimeZone(EVENT.deadline, 'America/Los_Angeles', 'MMMM do');

const regUrl = (content: string) => {
  const url = new URL(REG);
  url.searchParams.set('utm_source', 'yacoltburn.bike');
  url.searchParams.set('utm_medium', 'website');
  url.searchParams.set('utm_campaign', `ybe${EVENT.year}`);
  url.searchParams.set('utm_content', content);
  return url.toString();
};

const POSTER = cdn('/photos/poster.jpg', { w: '1920', q: '80' });
const MOBILE_POSTER = cdn('/photos/poster.jpg', { w: '828', q: '75' });

// og:image — absolute URL (crawlers need it) + JPG override (social scrapers prefer it over WebP)
const OG_IMAGE = `${SITE}${cdn('/photos/poster.jpg', { w: '800', q: '85', format: 'jpg' })}`;

// Mobile "get directions" deep link: from the user's location to the trailhead,
// FORCED through the NE Livingston Rd → L-1000 junction so it always takes the
// southern forest-road approach and never routes onto (closed) NE Rawson Rd.
const DIRECTIONS_URL = `https://www.google.com/maps/dir/?api=1&destination=45.751987,-122.327258&waypoints=45.67882,-122.36161&travelmode=driving`;

// Trailforks region page for the Yacolt Burn network (alias from trailforks.json).
const TRAILFORKS_URL = 'https://www.trailforks.com/region/yacolt-burn-state-forest/';

// "34 mi · ~1 hr 5 min" summary for a selected origin, from the OSRM stats
// stored on each route line (rounded to whole miles / nearest 5 minutes).
const driveStats = (route: (typeof GETTING_THERE_ROUTES)[number]) => {
  const { distance_km: km, duration_min: min } = route.line.properties ?? {};
  if (typeof km !== 'number' || typeof min !== 'number') return null;
  const mi = Math.round(km * 0.621371);
  const rounded = Math.round(min / 5) * 5;
  const time =
    rounded < 60
      ? `${rounded} min`
      : `${Math.floor(rounded / 60)} hr${rounded % 60 ? ` ${rounded % 60} min` : ''}`;
  return `${mi} mi · ~${time} to the trailhead`;
};

const IMG = {
  legend: cdn('/photos/pnw-forest-misty.jpg', { w: '1920', q: '70' }),
  ride: cdn('/photos/mtb-trail-forest.jpg', { w: '1920', q: '70' }),
  gallery: cdn('/photos/bikes-parked.jpg', { w: '1920', q: '70' }),
  details: cdn('/photos/hood.jpg', { w: '1920', q: '70' }),
  quote: cdn('/photos/trail-building.jpg', { w: '1920', q: '70' }),
  faq: cdn('/photos/hanging-bike.jpg', { w: '1200', q: '70' }),
  sponsors: cdn('/photos/forest-path.jpg', { w: '1920', q: '70' }),
  cta: cdn('/photos/mtb-sunset.jpg', { w: '1920', q: '70' }),
  gettingThere: cdn('/photos/gravel-road.jpg', { w: '1920', q: '70' }),
};

const MOBILE_IMG = {
  legend: cdn('/photos/pnw-forest-misty.jpg', { w: '828', q: '70' }),
  ride: cdn('/photos/mtb-trail-forest.jpg', { w: '828', q: '70' }),
  gallery: cdn('/photos/bikes-parked.jpg', { w: '828', q: '70' }),
  details: cdn('/photos/hood.jpg', { w: '828', q: '70' }),
  quote: cdn('/photos/trail-building.jpg', { w: '828', q: '70' }),
  faq: cdn('/photos/hanging-bike.jpg', { w: '828', q: '70' }),
  sponsors: cdn('/photos/forest-path.jpg', { w: '828', q: '70' }),
  cta: cdn('/photos/mtb-sunset.jpg', { w: '828', q: '70' }),
  gettingThere: cdn('/photos/gravel-road.jpg', { w: '828', q: '70' }),
};

const JSON_LD = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SportsEvent',
  name: EVENT.name,
  description:
    'A full-day mountain bike shuttle event in the Yacolt Burn State Forest, southwest Washington.',
  startDate: EVENT.isoStart,
  endDate: EVENT.isoEnd,
  url: SITE,
  image: OG_IMAGE,
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  location: {
    '@type': 'Place',
    name: 'Yacolt Burn Trailhead',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Yacolt',
      addressRegion: 'WA',
      postalCode: '98675',
      addressCountry: 'US',
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: 45.751958,
      longitude: -122.327047,
    },
  },
  organizer: {
    '@type': 'Organization',
    name: 'Evergreen Mountain Bike Alliance Southwest Chapter',
    url: 'https://www.evergreenmtb.org/chapters/southwest',
  },
  offers: {
    '@type': 'Offer',
    price: String(EVENT.priceMember),
    priceCurrency: 'USD',
    validFrom: '2026-01-01',
    validThrough: `${EVENT.year}-06-19`,
    url: REG,
    availability: 'https://schema.org/LimitedAvailability',
  },
});

const SPONSORS = sponsorsEntry.data;
---

<BaseLayout
  title={EVENT.name}
  description={DESCRIPTION}
  x-data="{}"
  :class="{ 'overflow-hidden': $store.ui.galleryOpen }"
  data-event-end={EVENT.isoEnd}
  data-deadline={EVENT.deadline.toISOString()}
>
  <Fragment slot="head">
    <SEO title={EVENT.name} description={DESCRIPTION} url={SITE} image={OG_IMAGE} />

    <!-- Preload LCP image — mobile and desktop sizes -->
    <link
      rel="preload"
      as="image"
      href={MOBILE_POSTER}
      fetchpriority="high"
      media="(max-width: 768px)"
    />
    <link rel="preload" as="image" href={POSTER} fetchpriority="high" media="(min-width: 769px)" />

    <!-- DNS prefetch for external links -->
    <link rel="dns-prefetch" href="https://maps.app.goo.gl" />
    <link rel="dns-prefetch" href="https://www.trailforks.com" />
    <link rel="dns-prefetch" href="https://www.evergreenmtb.org" />

    <!-- JSON-LD Event schema -->
    <script type="application/ld+json" set:html={JSON_LD} />
  </Fragment>

  <!-- Skip link for keyboard/screenreader users -->
  <a
    href="#experience"
    class="fixed -top-full left-4 z-1000 bg-amber-700 text-stone-100 px-4 py-2 rounded-sm text-sm font-semibold no-underline transition-[top] duration-200 focus:top-4"
    >Skip to content</a
  >

  <!-- NAV -->
  <Nav reg={regUrl('nav')} dateShort={EVENT.dateShort} datetime={EVENT.isoStart} />

  <!-- ── 1 · HERO ── -->
  <Panel id="hero" bgImage={POSTER} mobileBgImage={MOBILE_POSTER} priority fadeDown>
    <!-- Day-of banner — shown only after the online deadline, before the event ends. -->
    <Alert
      variant="warning"
      x-show="$store.ybe.onlineClosed && !$store.ybe.isPast"
      x-cloak
      class="mb-6 text-left"
    >
      <AlertTitle
        ><TriangleAlert size={18} strokeWidth={2.5} />Online registration is closed.</AlertTitle
      >
      <AlertDescription
        >Day-of, in-person registration is available at the trailhead for ${
          EVENT.priceDayOf
        }.</AlertDescription
      >
    </Alert>
    <DateLocation date={EVENT.date} datetime={EVENT.isoStart} />
    <HeadingRainbow size="xl" as="h1" reveal={false} class="animate-blur-in">
      Yacolt<br />Burn<br />Experience
    </HeadingRainbow>
    <Lead>
      A full-day shuttle event deep in the heart of<br />
      <strong
        ><a
          href="https://dnr.wa.gov/forest-and-trust-lands/yacolt-burn-state-forest"
          target="_blank"
          rel="noopener noreferrer"
          class="text-stone-100 underline decoration-amber-700 underline-offset-4 transition-colors duration-200 hover:decoration-amber-500"
          >Yacolt Burn State Forest</a
        ></strong
      >.
    </Lead>
    <p
      class="hero__stat text-shadow-lg font-display text-[clamp(1.6rem,5vw,2.8rem)] tracking-[0.06em] leading-none flex flex-wrap justify-center gap-x-[1.1rem] gap-y-[0.3rem] mt-5 mx-auto max-w-none"
    >
      <span class="text-amber-500 opacity-0 animate-fade-up [animation-delay:0.5s]"
        >{EVENT.capacity} riders.</span
      >
      <span class="text-amber-500 opacity-0 animate-fade-up [animation-delay:0.85s]"
        >All the trails.</span
      >
      <span class="text-amber-500 opacity-0 animate-fade-up [animation-delay:1.2s]">One day.</span>
    </p>
    <div class="btn__group flex flex-row flex-wrap items-center justify-center gap-3 mt-10">
      <div x-show="!$store.ybe.isPast" class="contents">
        <Button
          variant="fire"
          href={regUrl('hero')}
          target="_blank"
          rel="noopener noreferrer"
          class="!w-auto"
          :class="{ 'pointer-events-none opacity-40 saturate-50': $store.ybe.onlineClosed }"
          :aria-disabled="$store.ybe.onlineClosed"
          :tabindex="$store.ybe.onlineClosed ? -1 : null"
          :title="$store.ybe.onlineClosed ? 'Online registration has closed' : null"
          ><Ticket slot="icon-left" size={16} strokeWidth={2} /><span class="md:hidden"
            >Register</span
          ><span class="hidden md:inline">Register Now</span></Button
        >
      </div>
      <div x-show="$store.ybe.isPast" x-cloak>
        <p class="text-sm font-semibold tracking-widest uppercase text-stone-400">
          Registration closed. Follow <a
            href="https://www.evergreenmtb.org"
            target="_blank"
            rel="noopener"
            class="text-amber-600 hover:text-amber-500 transition-colors">Evergreen MTB</a
          > for {EVENT.year + 1} dates
        </p>
      </div>
      <Button variant="naked" href="#experience" class="!w-auto"
        ><span class="md:hidden">Explore</span><span class="hidden md:inline">What to Expect</span
        ><ArrowDown slot="icon-right" size={15} strokeWidth={2} /></Button
      >
    </div>
    <div class="mt-6 text-center">
      <a
        href="/volunteer"
        class="text-sm font-semibold tracking-widest uppercase text-stone-200 underline decoration-amber-700 underline-offset-4 transition-colors duration-200 hover:text-stone-100 hover:decoration-amber-500"
      >
        We need volunteers!
      </a>
    </div>
    <PhotoCredit
      label="Art by"
      name="Kathryn Jasperson"
      url="https://kathrynjaspersonart.com/"
      slot="credit"
    />
  </Panel>

  <!-- ── 2. STATS BAND ── -->
  <section class="relative overflow-hidden bg-stone-950 py-16 md:py-20 text-center">
    <div class="relative z-10 max-w-sm mx-auto px-6 flex flex-col items-center gap-10">
      <!-- Headline -->
      <p class="text-base font-bold italic tracking-widest uppercase text-stone-100">
        First come, first send.
      </p>

      <!-- Spots remaining + progress bar (shared viewport trigger) -->
      <div
        x-data={`seatsLeft(${EVENT.capacity}, ${EVENT.registered})`}
        class="flex flex-col items-center gap-10 w-full"
      >
        <div class="flex flex-col items-center gap-2">
          <span
            x-text="displayed"
            class="font-display text-8xl md:text-9xl tracking-[0.04em] leading-none text-amber-500 tabular-nums drop-shadow-[0_0_40px_rgba(245,158,11,0.5)]"
          ></span>
          <span class="text-xs tracking-widest uppercase text-stone-400">spots left</span>
        </div>

        <div class="w-full flex flex-col items-center gap-2.5">
          <Progress
            value={0}
            max={EVENT.capacity}
            variant="warning"
            class="h-2.5 bg-stone-800"
            aria-label="Registration spots claimed"
          />
          <p class="text-xs tracking-widest uppercase text-stone-500">
            <span x-text="registered">{EVENT.registered}</span> of {EVENT.capacity} spots claimed
          </p>
        </div>
      </div>

      <!-- Before the deadline: live countdown to ONLINE registration close -->
      <div x-show="!$store.ybe.onlineClosed" class="flex w-full flex-col items-center gap-2.5">
        <div
          x-data={`countdown(${EVENT.deadline.getTime()})`}
          class="flex w-full flex-nowrap items-baseline justify-center gap-1.5"
        >
          <span
            :class="{ 'tick-pulse': ticking }"
            class="font-display text-5xl tracking-[0.04em] leading-none text-yellow-400 drop-shadow-[0_0_12px_rgba(254,202,87,0.6)]"
            x-text="days"></span>
          <span class="text-xs tracking-widest uppercase text-stone-500">d</span>
          <span class="text-stone-700 mx-1">·</span>
          <span
            :class="{ 'tick-pulse': ticking }"
            class="font-display text-5xl tracking-[0.04em] leading-none text-cyan-400 drop-shadow-[0_0_12px_rgba(72,219,251,0.6)]"
            x-text="hours"></span>
          <span class="text-xs tracking-widest uppercase text-stone-500">h</span>
          <span class="text-stone-700 mx-1">·</span>
          <span
            :class="{ 'tick-pulse': ticking }"
            class="font-display text-5xl tracking-[0.04em] leading-none text-purple-400 drop-shadow-[0_0_12px_rgba(197,110,245,0.6)]"
            x-text="minutes"></span>
          <span class="text-xs tracking-widest uppercase text-stone-500">m</span>
          <span class="ml-1.5 text-xs tracking-widest whitespace-nowrap uppercase text-stone-400"
            >to register online</span
          >
        </div>
        <a
          href="#pricing"
          class="inline-flex items-center gap-1 text-xs tracking-widest text-amber-500 uppercase no-underline transition-colors hover:text-amber-400"
          >Day-of price increases<ArrowDown size={15} strokeWidth={2} /></a
        >
      </div>

      <!-- After the deadline (but before the event ends): day-of messaging -->
      <div
        x-show="$store.ybe.onlineClosed && !$store.ybe.isPast"
        x-cloak
        class="flex w-full flex-col items-center gap-2 text-center"
      >
        <p
          class="font-display text-4xl tracking-[0.04em] text-amber-400 drop-shadow-[0_0_12px_rgba(254,202,87,0.5)]"
        >
          Online registration closed
        </p>
        <a
          href="#getting-there"
          class="inline-flex items-center gap-1 text-xs tracking-widest whitespace-nowrap text-stone-300 uppercase no-underline transition-colors hover:text-amber-400"
          >Register day-of at the trailhead · ${EVENT.priceDayOf}<ArrowDown
            size={15}
            strokeWidth={2}
          /></a
        >
      </div>
    </div>
  </section>

  <!-- ── 3 · THE EXPERIENCE ── -->
  <Panel id="experience" bgImage={IMG.ride} mobileBgImage={MOBILE_IMG.ride} fadeUp>
    <img
      src={cdn('/logo.png', { w: '288', h: '288' })}
      alt="Yacolt Burn Experience"
      width="2796"
      height="2743"
      loading="lazy"
      decoding="async"
      class="h-36 w-auto block mx-auto mb-6"
    />
    <Eyebrow>The Event</Eyebrow>
    <HeadingRainbow>The Full Day</HeadingRainbow>
    <Rule />
    <Lead>
      All-day shuttles. Demo bikes. <ContentLink href="#faq-food">Food</ContentLink>. Trails that
      took decades to build. Yours for one day.
    </Lead>
    <Content>
      <p class="mb-5">
        YBE runs <strong>{EVENT.startTime} to {EVENT.endTime}</strong>. Shuttles load at the <ContentLink
          href="https://maps.app.goo.gl/fafFzUThcHkEMmTdA"
          target="_blank"
          rel="noopener noreferrer">lower Yacolt Burn Trailhead</ContentLink
        > and drop riders at <ContentLink
          href="https://www.trailforks.com/region/yacolt-burn-state-forest/?activitytype=1&z=15.8&lat=45.73092&lon=-122.30301&content=trails,labels,region,poi,directory,polygon,waypoint,nst,routes_featured"
          target="_blank"
          rel="noopener noreferrer">Five Corners</ContentLink
        >, gateway to the lower trail system. Ride down. Load back up. Repeat. There are rumors
        shuttles may go all the way to <ContentLink
          href="https://www.trailforks.com/region/yacolt-burn-state-forest/?activitytype=1&z=16.0&lat=45.71673&lon=-122.29648&content=trails,labels,region,poi,directory,polygon,waypoint,nst,routes_featured"
          target="_blank"
          rel="noopener noreferrer">The Towers</ContentLink
        >.
      </p>
      <p class="mb-5">
        The event caps at <strong>{EVENT.capacity} riders</strong> and historically fills up fast, rain
        or shine. Demo fleets from <strong>Norco</strong> and <strong>Propain</strong> are on-site.
        <strong>Vendors, <ContentLink href="#faq-food">food</ContentLink>, and raffles</strong> round
        out the day.
      </p>
      <p class="mb-5">
        The trail system is anchored by four standouts: <ContentLink
          href="https://www.trailforks.com/trails/cold-creek/"
          target="_blank"
          rel="noopener noreferrer">Cold Creek</ContentLink
        >, wild and rooty and rocky with the occasional burst of flow; <ContentLink
          href="https://www.trailforks.com/trails/sixth-sense/"
          target="_blank"
          rel="noopener noreferrer">Sixth Sense</ContentLink
        >, hand-crafted and flowy with the best berms in the forest; <ContentLink
          href="https://www.trailforks.com/trails/murphy-s-grade-98596/"
          target="_blank"
          rel="noopener noreferrer">Murphy's Grade</ContentLink
        >, hand-built by Carson Storch with fast doubles and plenty of speed; and <ContentLink
          href="https://www.trailforks.com/trails/thrillium/"
          target="_blank"
          rel="noopener noreferrer">Thrillium</ContentLink
        >, the sender: big, fast, and full of gnarly tabletops.
      </p>
      <p class="">
        You need a <ContentLink
          href="https://www.discoverpass.wa.gov/"
          target="_blank"
          rel="noopener noreferrer">Washington Discover Pass</ContentLink
        > to park at the event!
      </p>
    </Content>
    <Button
      variant="amber"
      href={regUrl('experience')}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-10"
      :class="{ 'pointer-events-none opacity-40 saturate-50': $store.ybe.onlineClosed }"
      :aria-disabled="$store.ybe.onlineClosed"
      :tabindex="$store.ybe.onlineClosed ? -1 : null"
      :title="$store.ybe.onlineClosed ? 'Online registration has closed' : null"
      ><CheckCircle slot="icon-left" size={16} strokeWidth={2} />Claim Your Spot</Button
    >

    <!-- Cascadia Dirt Cup easter egg -->
    <Collapsible class="mt-6 text-center">
      <CollapsibleTrigger
        class="group inline-flex items-center gap-2 text-sm font-bold italic text-stone-400 hover:text-stone-200 transition-colors duration-200"
      >
        Psst. Are you a Cascadia Dirt Cup racer?
        <ChevronDown
          size={14}
          strokeWidth={2.5}
          class="transition-transform duration-300 group-data-[panel-open]:rotate-180"
        />
      </CollapsibleTrigger>
      <CollapsibleContent class="mt-4 max-w-lg mx-auto text-sm text-stone-400 leading-relaxed">
        YBE takes place the week before the <a
          href="https://www.racecascadia.com/yacolt2026?utm_source=yacoltburn.bike&utm_medium=referral&utm_campaign=ybe2026&utm_content=cdc-collapsible"
          target="_blank"
          rel="noopener"
          class="text-amber-600 underline underline-offset-2 hover:text-amber-500 transition-colors font-medium not-italic"
          >Cascadia Dirt Cup race at Yacolt Burn</a
        >. Skip the climbs a week early and practice the descents.
      </CollapsibleContent>
    </Collapsible>
    <PhotoCredit
      name="Tim Foster"
      url="https://unsplash.com/@timberfoster"
      source="Unsplash"
      slot="credit"
    />
  </Panel>

  <!-- ── 4 · DETAILS ── -->
  <Panel id="details" bgImage={IMG.details} mobileBgImage={MOBILE_IMG.details}>
    <Eyebrow><time datetime={EVENT.isoStart}>{EVENT.date}</time></Eyebrow>
    <HeadingRainbow>Event Details</HeadingRainbow>
    <Rule />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mt-12 text-left">
      <Card size="sm" class="bg-white/5 rounded ring-white/10">
        <CardHeader>
          <CardTitle
            class="flex items-center gap-1.5 text-xs tracking-wide uppercase text-amber-700"
          >
            <CalendarDays size={12} strokeWidth={2.5} />
            Date & Time
          </CardTitle>
        </CardHeader>
        <CardContent class="text-sm text-stone-100">
          <time datetime={EVENT.isoStart}>{EVENT.dateDay}</time><br />{EVENT.startTime} – <time
            datetime={EVENT.isoEnd}>{EVENT.endTime}</time
          >
        </CardContent>
      </Card>
      <Card size="sm" class="bg-white/5 rounded ring-white/10">
        <CardHeader>
          <CardTitle
            class="flex items-center gap-1.5 text-xs tracking-wide uppercase text-amber-700"
          >
            <MapPin size={12} strokeWidth={2.5} />
            Location
          </CardTitle>
        </CardHeader>
        <CardContent class="text-sm text-stone-100">
          <a
            href="https://maps.app.goo.gl/fafFzUThcHkEMmTdA"
            class="underline underline-offset-2"
            target="_blank"
