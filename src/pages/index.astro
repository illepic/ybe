<script>
  // Prevent the browser restoring scroll position on refresh, which combined
  // with scroll-behavior: smooth on <html> causes a visible scroll-to-top animation
  if ('scrollRestoration' in history) history.scrollRestoration = 'manual';

  const registerHashClear = () => {
    if (!location.hash) return;
    window.addEventListener(
      'scroll',
      () => {
        const clear = () => history.replaceState(null, '', location.pathname);
        'requestIdleCallback' in window ? requestIdleCallback(clear) : clear();
      },
      { once: true, passive: true }
    );
  };

  registerHashClear();
  window.addEventListener('hashchange', registerHashClear);

  // Lazy-load below-the-fold panel backgrounds ~one viewport before they enter view
  const lazyBg = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const { bgDesktop, bgMobile } = el.dataset;
        if (bgDesktop) el.style.setProperty('--bg-desktop', `url('${bgDesktop}')`);
        if (bgMobile) el.style.setProperty('--bg-mobile', `url('${bgMobile}')`);
        lazyBg.unobserve(el);
      });
    },
    { rootMargin: '100% 0px' }
  );

  document.querySelectorAll('.panel--lazy-bg').forEach((el) => lazyBg.observe(el));
</script>
