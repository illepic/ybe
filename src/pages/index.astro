---
import '../styles/tailwind.css';
import PhotoCredit from '../components/PhotoCredit.astro';
import Countdown from '../components/Countdown.astro';
import HeadingRainbow from '../components/HeadingRainbow.astro';
import Nav from '../components/Nav.astro';
import Panel from '../components/Panel.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Button from '../components/Button.astro';
import Lead from '../components/Lead.astro';
import Rule from '../components/Rule.astro';
import Content from '../components/Content.astro';
import ContentLink from '../components/ContentLink.astro';
import DetailCard from '../components/DetailCard.astro';
import Pricing from '../components/Pricing.astro';
import PricingRow from '../components/PricingRow.astro';
import DateLocation from '../components/DateLocation.astro';
import Faq from '../components/Faq.astro';
import FaqItem from '../components/FaqItem.astro';
import {
  ArrowDown,
  ArrowRight,
  ArrowUp,
  ArrowUpRight,
  Bike,
  CalendarDays,
  CheckCircle,
  Flame,
  ChevronDown,
  ChevronLeft,
  ChevronRight,
  Clock,
  MapPin,
  Medal,
  Minus,
  Package,
  Plus,
  Tag,
  Ticket,
  Users,
  X,
} from 'lucide-astro';

// ─── UPDATE THESE EACH YEAR ───────────────────────────────────────────────
const EVENT = {
  year: 2026,
  name: 'Yacolt Burn Experience 2026',
  date: 'June 20, 2026',
  dateShort: 'June 20',
  dateDay: 'Saturday, June 20, 2026',
  startTime: '9:00 AM',
  endTime: '4:00 PM',
  deadline: 'June 19th',
  isoStart: '2026-06-20T09:00:00-07:00',
  isoEnd: '2026-06-20T16:00:00-07:00',
  capacity: 299,
  priceMember: 35,
  priceGuest: 60,
  priceDayOf: 70,
};

const REG =
  'https://www.evergreenmtb.org/component/civicrm?task=civicrm/event/info&reset=1&id=5398';
const SITE = import.meta.env.SITE ?? 'https://yacoltburn.bike';

// Netlify Image CDN helper — transforms on deploy, raw path in local dev
const IS_DEV = import.meta.env.DEV;
const cdn = (path: string, params: Record<string, string> = {}) => {
  if (IS_DEV) return path;
  const p = new URLSearchParams({ url: path, format: 'webp', ...params });
  return `/.netlify/images?${p}`;
};

const POSTER = cdn('/photos/poster.jpg', { w: '1920', q: '85' });

// og:image — absolute URL, JPG (not WebP), standard portrait crop
const OG_IMAGE = `${SITE}/.netlify/images?url=/photos/poster.jpg&w=800&format=jpg&q=85`;

const IMG = {
  legend: cdn('/photos/pnw-forest-misty.jpg', { w: '1920', q: '80' }),
  ride: cdn('/photos/mtb-trail-forest.jpg', { w: '1920', q: '80' }),
  gallery: cdn('/photos/bikes-parked.jpg', { w: '1920', q: '80' }),
  details: cdn('/photos/hood.jpg', { w: '1920', q: '80' }),
  quote: cdn('/photos/trail-building.jpg', { w: '1920', q: '80' }),
  faq: cdn('/photos/hanging-bike.jpg', { w: '1920', q: '80' }),
  sponsors: cdn('/photos/forest-path.jpg', { w: '1920', q: '80' }),
  cta: cdn('/photos/mtb-sunset.jpg', { w: '1920', q: '80' }),
};

const JSON_LD = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SportsEvent',
  name: EVENT.name,
  description:
    'A full-day mountain bike shuttle event in the Yacolt Burn State Forest, southwest Washington.',
  startDate: EVENT.isoStart,
  endDate: EVENT.isoEnd,
  url: SITE,
  image: OG_IMAGE,
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  location: {
    '@type': 'Place',
    name: 'Yacolt Burn Trailhead',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Yacolt',
      addressRegion: 'WA',
      postalCode: '98675',
      addressCountry: 'US',
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: 45.7309,
      longitude: -122.303,
    },
  },
  organizer: {
    '@type': 'Organization',
    name: 'Evergreen Mountain Bike Alliance Southwest Chapter',
    url: 'https://www.evergreenmtb.org/chapters/southwest',
  },
  offers: {
    '@type': 'Offer',
    price: String(EVENT.priceMember),
    priceCurrency: 'USD',
    validFrom: '2026-01-01',
    validThrough: `${EVENT.year}-06-19`,
    url: 'https://www.evergreenmtb.org/component/civicrm?task=civicrm/event/info&reset=1&id=5398',
    availability: 'https://schema.org/LimitedAvailability',
  },
});
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{EVENT.name}</title>
    <meta
      name="description"
      content={`A full-day shuttle MTB event in the Yacolt Burn State Forest, southwest Washington. ${EVENT.date}.`}
    />

    <!-- Canonical & OG -->
    <link rel="canonical" href={SITE} />
    <meta name="theme-color" content="#100e0c" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={SITE} />
    <meta property="og:title" content={EVENT.name} />
    <meta
      property="og:description"
      content={`A full-day shuttle MTB event in the Yacolt Burn State Forest, southwest Washington. ${EVENT.date}.`}
    />
    <meta property="og:image" content={OG_IMAGE} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={EVENT.name} />
    <meta
      name="twitter:description"
      content={`A full-day shuttle MTB event in the Yacolt Burn State Forest, southwest Washington. ${EVENT.date}.`}
    />
    <meta name="twitter:image" content={OG_IMAGE} />

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Preload LCP image -->
    <link rel="preload" as="image" href={POSTER} fetchpriority="high" />

    <!-- DNS prefetch for external links -->
    <link rel="dns-prefetch" href="https://maps.app.goo.gl" />
    <link rel="dns-prefetch" href="https://www.trailforks.com" />
    <link rel="dns-prefetch" href="https://www.evergreenmtb.org" />

    <!-- JSON-LD Event schema -->
    <script type="application/ld+json" set:html={JSON_LD} />
  </head>
  <body class="antialiased text-base/relaxed bg-bg text-text font-body">
    <!-- Skip link for keyboard/screenreader users -->
    <a
      href="#experience"
      class="fixed -top-full left-4 z-1000 bg-accent text-text px-4 py-2 rounded-[2px] text-[0.85rem] font-semibold no-underline transition-[top] duration-200 focus:top-4"
      >Skip to content</a
    >

    <!-- NAV -->
    <Nav reg={REG} dateShort={EVENT.dateShort} datetime={EVENT.isoStart} />

    <!-- ── 1 · HERO ── -->
    <Panel id="hero" bgImage={POSTER}>
      <DateLocation date={EVENT.date} datetime={EVENT.isoStart} />
      <HeadingRainbow size="xl" as="h1" reveal={false}>
        Yacolt<br />Burn<br />Experience
      </HeadingRainbow>
      <Lead>
        A full-day shuttle event deep in the heart of<br />
        <strong
          ><a
            href="https://dnr.wa.gov/forest-and-trust-lands/yacolt-burn-state-forest"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text underline decoration-accent underline-offset-4 transition-colors duration-200 hover:decoration-amber"
            >Yacolt Burn State Forest</a
          ></strong
        >.
      </Lead>
      <p
        class="hero__stat text-shadow-lg font-display text-[clamp(1.6rem,5vw,2.8rem)] tracking-[0.06em] leading-none flex flex-wrap justify-center gap-x-[1.1rem] gap-y-[0.3rem] mt-5 mx-auto max-w-none"
      >
        <span
          class="text-amber opacity-0 [animation:fadeUp_0.55s_ease_forwards] [animation-delay:0.5s]"
          >{EVENT.capacity} riders.</span
        >
        <span
          class="text-amber opacity-0 [animation:fadeUp_0.55s_ease_forwards] [animation-delay:0.85s]"
          >All the trails.</span
        >
        <span
          class="text-amber opacity-0 [animation:fadeUp_0.55s_ease_forwards] [animation-delay:1.2s]"
          >One day.</span
        >
      </p>
      <div
        class="btn__group flex flex-col items-center gap-4 flex-wrap md:flex-row md:justify-center mt-10"
      >
        <Button variant="fire" href={REG} target="_blank" rel="noopener noreferrer"
          ><Ticket slot="icon-left" size={16} strokeWidth={2} />Register Now</Button
        >
        <Button variant="ghost" href="#experience"
          >What to Expect<ChevronDown slot="icon-right" size={15} strokeWidth={2} /></Button
        >
      </div>
      <Countdown targetDate={EVENT.isoStart} />
      <PhotoCredit
        label="Art by"
        name="Kathryn Jasperson"
        url="https://kathrynjaspersonart.com/"
        slot="credit"
      />
    </Panel>

    <!-- ── 2 · THE EXPERIENCE ── -->
    <Panel id="experience" bgImage={IMG.ride}>
      <img
        src="/logo.png"
        alt="Yacolt Burn Experience"
        class="h-[120px] w-auto block mx-auto mb-6"
      />
      <Eyebrow>The Event</Eyebrow>
      <HeadingRainbow>The Full Day</HeadingRainbow>
      <Rule />
      <Lead>
        All-day shuttles. Demo bikes. Food. Trails that took decades to build. Yours for one day.
      </Lead>
      <Content>
        <p class="mb-5">
          YBE runs 9am to 4pm. Shuttles load at the <a
            href="https://maps.app.goo.gl/fafFzUThcHkEMmTdA"
            class="loc"
            target="_blank"
            rel="noopener noreferrer">lower Yacolt Burn Trailhead</a
          > and drop riders at <ContentLink
            href="https://www.trailforks.com/region/yacolt-burn-state-forest/?activitytype=1&z=15.8&lat=45.73092&lon=-122.30301&content=trails,labels,region,poi,directory,polygon,waypoint,nst,routes_featured"
            target="_blank"
            rel="noopener noreferrer">Five Corners</ContentLink
          >, gateway to the upper trail system. Ride down. Load back up. Repeat. There are rumors
          shuttles may go all the way to <ContentLink
            href="https://www.trailforks.com/region/yacolt-burn-state-forest/?activitytype=1&z=16.0&lat=45.71673&lon=-122.29648&content=trails,labels,region,poi,directory,polygon,waypoint,nst,routes_featured"
            target="_blank"
            rel="noopener noreferrer">The Towers</ContentLink
          >.
        </p>
        <p class="mb-5">
          The event caps at {EVENT.capacity} riders and sells out every single year, rain or shine. Demo
          fleets from Norco and Propain are on-site. Vendors, food, and raffles round out the day. There's
          even an organized youth ride for ages 3-12 and bike games for all levels.
        </p>
        <p class="">
          The trail system is anchored by four standouts: <ContentLink
            href="https://www.trailforks.com/trails/cold-creek/"
            target="_blank"
            rel="noopener noreferrer">Cold Creek</ContentLink
          >, wild and rooty and rocky with the occasional burst of flow; <ContentLink
            href="https://www.trailforks.com/trails/sixth-sense/"
            target="_blank"
            rel="noopener noreferrer">Sixth Sense</ContentLink
          >, hand-crafted and flowy with the best berms in the forest; <ContentLink
            href="https://www.trailforks.com/trails/murphy-s-grade-98596/"
            target="_blank"
            rel="noopener noreferrer">Murphy's Grade</ContentLink
          >, hand-built by Carson Storch with fast doubles and plenty of speed; and <ContentLink
            href="https://www.trailforks.com/trails/thrillium/"
            target="_blank"
            rel="noopener noreferrer">Thrillium</ContentLink
          >, the sender: big, fast, and full of gnarly tabletops.
        </p>
      </Content>
      <Button variant="amber" href={REG} target="_blank" rel="noopener noreferrer" class="mt-10"
        ><CheckCircle slot="icon-left" size={16} strokeWidth={2} />Claim Your Spot</Button
      >
      <PhotoCredit
        name="Tim Foster"
        url="https://unsplash.com/@timberfoster"
        source="Unsplash"
        slot="credit"
      />
    </Panel>

    <!-- ── 3 · DETAILS ── -->
    <Panel id="details" bgImage={IMG.details}>
      <Eyebrow><time datetime={EVENT.isoStart}>{EVENT.date}</time></Eyebrow>
      <HeadingRainbow>Event Details</HeadingRainbow>
      <Rule />

      <div class="detail-cards grid grid-cols-1 md:grid-cols-2 gap-5 mt-12 text-left">
        <DetailCard label="Date & Time">
          <CalendarDays slot="icon" size={12} strokeWidth={2.5} />
          <time datetime={EVENT.isoStart}>{EVENT.dateDay}</time><br />{EVENT.startTime} – <time
            datetime={EVENT.isoEnd}>{EVENT.endTime}</time
          >
        </DetailCard>
        <DetailCard label="Location">
          <MapPin slot="icon" size={12} strokeWidth={2.5} />
          <a
            href="https://maps.app.goo.gl/fafFzUThcHkEMmTdA"
            class="loc"
            target="_blank"
            rel="noopener noreferrer">Yacolt Burn Trailhead<br />Southwest Washington</a
          ><br />
          <small class="block text-muted text-[0.8rem] mt-[0.2rem]"
            >Park on the west side of the road</small
          >
        </DetailCard>
        <DetailCard label="What's Included">
          <Package slot="icon" size={12} strokeWidth={2.5} />
          All-day shuttles<br />Demo bikes (Norco · Propain)<br />Food · Raffles · Vendors<br />
          <small class="block text-muted text-[0.8rem] mt-[0.2rem]">Youth ride ages 3-12</small>
        </DetailCard>
        <DetailCard label="Capacity">
          <Users slot="icon" size={12} strokeWidth={2.5} />
          {EVENT.capacity} riders max<br />
          <small class="block text-muted text-[0.8rem] mt-[0.2rem]"
            >Sells out every year. Register early.</small
          >
        </DetailCard>
      </div>

      <div class="details-arrow flex justify-center my-8 text-pink">
        <ArrowDown size={24} strokeWidth={2.5} />
      </div>
      <Pricing>
        <PricingRow slot="rows" amount={EVENT.priceMember} note="Online · pre-event">
          Members <a
            href="https://www.evergreenmtb.org/support-us/become-a-member"
            target="_blank"
            class="text-accent no-underline italic text-[0.8rem]">(join)</a
          >
        </PricingRow>
        <PricingRow slot="rows" amount={EVENT.priceGuest} note="Online · pre-event">
          Non-Members
        </PricingRow>
        <PricingRow slot="rows" amount={EVENT.priceDayOf} note="All participants">
          Day-Of
        </PricingRow>
        <div slot="cta" class="mt-6 text-center">
          <Button variant="fire" href={REG} target="_blank" rel="noopener noreferrer"
            >Register by {EVENT.deadline}</Button
          >
        </div>
      </Pricing>
      <PhotoCredit label="Photo by" name="Todd McCarthy" slot="credit" />
    </Panel>

    <!-- ── 4 · GALLERY ── -->
    <Panel id="gallery" bgImage={IMG.gallery} scroll>
      <Eyebrow>From the Trails</Eyebrow>
      <HeadingRainbow>See You Out There</HeadingRainbow>
      <Rule />

      <!-- Replace Unsplash placeholders with real event photos in src/entrypoints/alpine.js -->
      <div x-data="photoGallery">
        <div class="gallery__grid">
          <template x-for="(photo, i) in photos" :key="i">
            <button class="gallery__thumb" @click="openAt(i)">
              <img :src="photo.thumb" :alt="photo.caption" loading="lazy" decoding="async" />
            </button>
          </template>
        </div>

        <div
          class="gallery__modal"
          x-cloak
          x-show="isOpen"
          x-transition:enter="transition ease-out duration-200"
          x-transition:enter-start="opacity-0"
          x-transition:enter-end="opacity-100"
          x-transition:leave="transition ease-in duration-150"
          x-transition:leave-start="opacity-100"
          x-transition:leave-end="opacity-0"
          x-trap="isOpen"
          x-effect="isOpen && $nextTick(() => $refs.modal.focus())"
          x-ref="modal"
          role="dialog"
          aria-modal="true"
          aria-label="Photo gallery"
          tabindex="-1"
          @keydown.escape="close()"
          @keydown.arrow-left="prev()"
          @keydown.arrow-right="next()"
        >
          <div class="gallery__backdrop" @click="close()"></div>
          <div class="gallery__frame">
            <div x-show="loading" class="absolute inset-0 flex items-center justify-center">
              <div
                class="w-10 h-10 rounded-full border-4 border-white/20 border-t-white/80 animate-spin"
              >
              </div>
            </div>
            <img
              x-ref="fullImg"
              :src="photos[current].full"
              :alt="photos[current].caption"
              @load="onImageLoad()"
              :class="loading ? 'opacity-0' : 'opacity-100'"
              class="transition-opacity duration-300"
            />
            <button
              class="gallery__btn gallery__btn--close"
              @click="close()"
              aria-label="Close gallery"><X size={18} strokeWidth={2} /></button
            >
            <button
              class="gallery__btn gallery__btn--prev"
              @click.stop="prev()"
              aria-label="Previous photo"><ChevronLeft size={22} strokeWidth={2} /></button
            >
            <button
              class="gallery__btn gallery__btn--next"
              @click.stop="next()"
              aria-label="Next photo"><ChevronRight size={22} strokeWidth={2} /></button
            >
          </div>
        </div>
      </div>
      <PhotoCredit
        name="Sean Benesh"
        url="https://unsplash.com/@seanbenesh"
        source="Unsplash"
        slot="credit"
      />
    </Panel>

    <!-- ── 5 · LEGEND ── -->
    <Panel id="legend" bgImage={IMG.legend}>
      <Eyebrow>A Place With History</Eyebrow>
      <HeadingRainbow>Born From Fire</HeadingRainbow>
      <Rule />
      <Lead>
        The Klickitat word <em>Yacolt</em> means "haunted valley," a place of legend long before a single
        trail was ever cut.
      </Lead>
      <Content>
        <p class="mb-5">
          On September 11, 1902, a firestorm swept through southwest Washington. Within 36 hours it
          consumed 238,920 acres, killed 38 people, rained ash on Portland, and triggered street
          lamps to switch on at noon in Seattle. The town of Yacolt nearly vanished before the wind
          direction changed.
        </p>
        <p class="mb-5">
          What followed was one of Washington's great rehabilitation stories: Civilian Conservation
          Corps crews in the 1930s, decades of DNR replanting, and a generation of mountain bikers
          who saw something in those old logging roads in the late 1990s and started riding them.
          The Yacolt Burn Experience is the product of all of it.
        </p>
        <a
          href="https://www.evergreenmtb.org/blog/yacolt-burn-experience-history"
          target="_blank"
          class="inline-block mt-8 text-accent underline underline-offset-[3px] text-[0.9rem]"
          >Read More</a
        >
      </Content>
      <PhotoCredit
        name="Sebastian Unrau"
        url="https://unsplash.com/@sebastian_unrau"
        source="Unsplash"
        slot="credit"
      />
    </Panel>

    <!-- ── 5 · PULL QUOTE ── -->
    <Panel id="trails" bgImage={IMG.quote}>
      <p
        class="pullquote text-shadow-lg font-display text-4xl md:text-6xl leading-none text-text max-w-3xl mx-auto mb-6"
      >
        "The trails you love<br /><em class="text-accent not-italic">are not free.</em>"
      </p>
      <Lead>
        Every trail in the Yacolt Burn exists because regular people showed up on a Saturday with
        hand tools and did the work. The Evergreen Mountain Bike Alliance is how that keeps
        happening.
      </Lead>
      <Button variant="logo" href="https://www.evergreenmtb.org" target="_blank">
        <span class="text-[0.85rem] font-semibold tracking-[0.12em] uppercase"
          >Join <ArrowRight size={13} strokeWidth={2.5} /></span
        >
        <img
          src="/sponsors/evergreen-mtb.png"
          alt="Evergreen Mountain Bike Alliance"
          class="h-[68px] w-auto opacity-90"
        />
      </Button>
      <PhotoCredit
        name="Tim Foster"
        url="https://unsplash.com/@timberfoster"
        source="Unsplash"
        slot="credit"
      />
    </Panel>

    <!-- ── 6 · FAQ ── -->
    <Panel id="faq" bgImage={IMG.faq}>
      <Eyebrow>Questions</Eyebrow>
      <HeadingRainbow>FAQ</HeadingRainbow>
      <Rule />
      <Faq>
        <FaqItem question="What skill level do I need?">
          The upper system accessed from Five Corners is intermediate to advanced terrain. The event
          welcomes all riders though, including a dedicated youth ride for ages 3-12. Volunteers and
          the community are there to help you find your line.
        </FaqItem>
        <FaqItem question="Does it sell out?">
          Every single year. Space is capped at {EVENT.capacity} riders. Register online by {EVENT.deadline} to lock in your spot and your best rate.
        </FaqItem>
        <FaqItem question="What if it rains?">
          The event runs rain or shine. It's historically 50/50 on weather. This is the Pacific Northwest. Pack a rain shell, bring layers, and embrace it.
        </FaqItem>
        <FaqItem question="Do I need to be an Evergreen member?">
          Nope, everyone is welcome. Members save $25 on registration though, and your trails depend on the Evergreen Mountain Bike Alliance. Basic membership is $50/year and pays for itself at events like this.
        </FaqItem>
        <FaqItem question="Can I try a demo bike?">
          Yep. Norco and Propain both bring demo fleets to the event. Availability is first-come, first-served on the day.
        </FaqItem>
        <FaqItem question="What trails are there to ride?">
          Four standouts: <ContentLink href="https://www.trailforks.com/trails/cold-creek/" target="_blank" rel="noopener noreferrer">Cold Creek</ContentLink> is wild and rooty with occasional flow. <ContentLink href="https://www.trailforks.com/trails/sixth-sense/" target="_blank" rel="noopener noreferrer">Sixth Sense</ContentLink> is hand-crafted and flowy with the best berms in the forest. <ContentLink href="https://www.trailforks.com/trails/murphy-s-grade-98596/" target="_blank" rel="noopener noreferrer">Murphy's Grade</ContentLink> was hand-built by Carson Storch with fast doubles and plenty of speed. <ContentLink href="https://www.trailforks.com/trails/thrillium/" target="_blank" rel="noopener noreferrer">Thrillium</ContentLink> is the sender: big, fast, and full of gnarly tabletops.
        </FaqItem>
        <FaqItem question="Where do I park?">
          <a href="https://maps.app.goo.gl/fafFzUThcHkEMmTdA" class="loc" target="_blank" rel="noopener noreferrer">Yacolt Burn Trailhead</a>. Park on the west side of the road. It fills early, so plan to arrive by 8:30 AM.
        </FaqItem>
      </Faq>
      <PhotoCredit label="Photo by" name="Todd McCarthy" slot="credit" />
    </Panel>

    <!-- ── 7 · SPONSORS ── -->
    <Panel id="sponsors" bgImage={IMG.sponsors}>
      <Eyebrow>Made Possible By</Eyebrow>
      <HeadingRainbow>{EVENT.year} Sponsors</HeadingRainbow>
      <Rule />
      <Lead>
        YBE exists because of this community of brands, shops, and people who show up every year to
        make it happen.
      </Lead>

      <div class="sponsor-tier">
        <div class="sponsor-tier__label sponsor-tier__label--gold">
          <Medal size={12} strokeWidth={2.5} /> Gold
        </div>
        <div class="sponsor-tier__row">
          <div class="sponsor-logo sponsor-logo--gold">
            <img src="/sponsors/norco.svg" alt="Norco" />
          </div>
        </div>
      </div>

      <div class="sponsor-tier">
        <div class="sponsor-tier__label sponsor-tier__label--silver">
          <Medal size={12} strokeWidth={2.5} /> Silver
        </div>
        <div class="sponsor-tier__row">
          <div class="sponsor-logo sponsor-logo--silver">
