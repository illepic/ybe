# Netlify credentials for `npm run reg:set` (pushing the live registration count
# to Netlify Blobs). Copy this file to `.env` and fill in the values.
# `.env` is git-ignored.

# Netlify personal access token: User settings → Applications → Personal access
# tokens → New access token.
NETLIFY_AUTH_TOKEN=

# Site API ID: Site configuration → General → Site details → Site ID.
NETLIFY_SITE_ID=
